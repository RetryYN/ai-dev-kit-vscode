#!/bin/bash
set -euo pipefail

# helix-pr: ゲート結果から PR テンプレート自動生成
# Usage: helix-pr [--dry-run] [--base main] [--title "title"]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
PHASE_FILE="$HELIX_DIR/phase.yaml"
MATRIX_FILE="$HELIX_DIR/matrix.yaml"

# --- 引数パース ---
DRY_RUN=false
BASE="main"
TITLE=""
REQUIRE_GATES_RAW=""
FORCE=false

require_opt_arg() {
  local opt_name="$1"
  if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == --* ]]; then
    echo "Error: $opt_name requires a value" >&2
    exit 2
  fi
}

while [[ $# -gt 0 ]]; do
  case $1 in
    --dry-run) DRY_RUN=true; shift ;;
    --base)
      require_opt_arg "$1" "${2-}"
      BASE="$2"
      shift 2
      ;;
    --title)
      require_opt_arg "$1" "${2-}"
      TITLE="$2"
      shift 2
      ;;
    --require-gates)
      require_opt_arg "$1" "${2-}"
      REQUIRE_GATES_RAW="$2"
      shift 2
      ;;
    --force) FORCE=true; shift ;;
    --help|-h)
      echo "Usage: helix-pr [--dry-run] [--base main] [--title \"title\"] [--require-gates G4,G6] [--force]"
      echo ""
      echo "Options:"
      echo "  --dry-run  PR を作成せずマークダウンを出力"
      echo "  --base     ベースブランチ (default: main)"
      echo "  --title    PR タイトル"
      echo "  --require-gates G4,G6  必須ゲートを明示指定（デフォルト判定を上書き）"
      echo "  --force    ゲート未通過でも警告表示で続行"
      exit 0
      ;;
    *) echo "Error: Unknown option: $1" >&2; exit 1 ;;
  esac
done

project_size=""
if [[ -f "$MATRIX_FILE" ]]; then
  project_size=$(python3 "$YAML_PARSER" read "$MATRIX_FILE" "project.size" 2>/dev/null || echo "")
fi
project_size="${project_size:-L}"

required_gates=()
if [[ -n "$REQUIRE_GATES_RAW" ]]; then
  IFS=',' read -r -a required_candidates <<< "$REQUIRE_GATES_RAW"
  for gate in "${required_candidates[@]}"; do
    gate="${gate// /}"
    [[ -n "$gate" ]] || continue
    if [[ ! "$gate" =~ ^G(0\.5|1|1R|1\.5|[2-7])$ ]]; then
      echo "Error: invalid gate in --require-gates: $gate" >&2
      exit 2
    fi
    if [[ " ${required_gates[*]} " != *" $gate "* ]]; then
      required_gates+=("$gate")
    fi
  done
else
  if [[ "$project_size" == "S" ]]; then
    required_gates=("G4")
  else
    required_gates=("G6")
  fi
fi

if [[ ! -f "$PHASE_FILE" ]]; then
  if [[ "$FORCE" == true ]]; then
    echo "警告: phase.yaml が見つからないためゲート状態の確認をスキップします (--force)" >&2
  else
    echo "エラー: phase.yaml が見つからないためゲート状態を確認できません。--force でバイパスできます。" >&2
    exit 1
  fi
else
  unmet=()
  for gate in "${required_gates[@]}"; do
    status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "gates.${gate}.status" 2>/dev/null || echo "pending")
    if [[ "$status" != "passed" ]]; then
      unmet+=("${gate}:${status:-pending}")
    fi
  done

  if [[ ${#unmet[@]} -gt 0 ]]; then
    if [[ "$FORCE" == true ]]; then
      echo "警告: 必須ゲート未通過ですが --force により継続します: ${unmet[*]}" >&2
    else
      echo "エラー: 必須ゲート未通過: ${unmet[*]}" >&2
      echo "ヒント: --require-gates で条件を明示、または --force で警告付きバイパス可能です。" >&2
      exit 1
    fi
  fi
fi

# --- ブランチ情報 ---
BRANCH=$(git -C "$PROJECT_ROOT" branch --show-current 2>/dev/null || echo "unknown")
if [[ -z "$TITLE" ]]; then
  TITLE="$BRANCH"
fi

# --- Conventional Commits からリリースノート生成 ---
append_release_section() {
  local heading="$1"
  local body="$2"
  local output="$3"
  [[ -z "$body" ]] && return 0

  printf "### %s\n" "$heading" >> "$output"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    printf -- "- %s\n" "$line" >> "$output"
  done <<< "$body"
  printf "\n" >> "$output"
}

generate_release_notes() {
  local base_branch="${1:-main}"
  local tmp
  tmp=$(mktemp /tmp/helix-pr-notes-XXXXXX)

  local feats fixes docs
  feats=$(git -C "$PROJECT_ROOT" log "$base_branch"..HEAD --oneline --grep='^feat' 2>/dev/null || true)
  fixes=$(git -C "$PROJECT_ROOT" log "$base_branch"..HEAD --oneline --grep='^fix' 2>/dev/null || true)
  docs=$(git -C "$PROJECT_ROOT" log "$base_branch"..HEAD --oneline --grep='^docs' 2>/dev/null || true)

  append_release_section "新機能" "$feats" "$tmp"
  append_release_section "バグ修正" "$fixes" "$tmp"
  append_release_section "ドキュメント" "$docs" "$tmp"

  if [[ ! -s "$tmp" ]]; then
    echo "（Conventional Commits の feat/fix/docs は検出されませんでした）"
  else
    cat "$tmp"
  fi
  rm -f "$tmp"
}

# --- Summary（コミットから） ---
COMMITS=$(git -C "$PROJECT_ROOT" log --oneline "$BASE..HEAD" 2>/dev/null || echo "(no commits)")
RELEASE_NOTES=$(generate_release_notes "$BASE")

# --- Changes ---
DIFF_STAT=$(git -C "$PROJECT_ROOT" diff --stat "$BASE..HEAD" 2>/dev/null || echo "(no diff)")

# --- Gate Results ---
GATE_TABLE=""
if [[ -f "$PHASE_FILE" ]]; then
  PHASE_JSON=$(python3 "$YAML_PARSER" dump "$PHASE_FILE" 2>/dev/null || echo "{}")
  GATE_TABLE=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
gates = d.get('gates', {})
lines = ['| Gate | Status | Date |', '|------|--------|------|']
for g in ['G1', 'G1.5', 'G1R', 'G2', 'G3', 'G4', 'G5', 'G6', 'G7']:
    v = gates.get(g, {})
    s = v.get('status', 'pending') if isinstance(v, dict) else 'pending'
    dt = v.get('date', '—') if isinstance(v, dict) else '—'
    if s != 'pending':
        lines.append(f'| {g} | {s} | {dt} |')
print('\n'.join(lines))
" 2>/dev/null)
fi

# --- Sprint Status ---
SPRINT_STATUS=""
if [[ -f "$PHASE_FILE" ]]; then
  sprint_step=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(d.get('sprint', {}).get('current_step', '') or 'N/A')
" 2>/dev/null || echo "N/A")
  if [[ "$sprint_step" != "N/A" ]]; then
    SPRINT_STATUS="Sprint: $sprint_step"
  fi
fi

# --- PR Body 構築 ---
BODY="## Summary

$(echo "$COMMITS" | head -20)

## Release Notes

$RELEASE_NOTES

## Gate Results

$(printf "$GATE_TABLE")

${SPRINT_STATUS:+## Sprint Status
$SPRINT_STATUS
}
## Changes

\`\`\`
$(echo "$DIFF_STAT" | head -30)
\`\`\`

## Test Plan
- [ ] 静的チェック通過（lint, type check）
- [ ] ユニットテスト通過
- [ ] 手動確認完了

---
Generated by \`helix-pr\`"

# --- 実行 ---
if [[ "$DRY_RUN" == true ]]; then
  echo "=== PR Preview ==="
  echo "Title: $TITLE"
  echo "Base:  $BASE"
  echo "Branch: $BRANCH"
  echo ""
  echo "$BODY"
else
  if ! command -v gh >/dev/null 2>&1; then
    echo "Error: gh (GitHub CLI) not found" >&2
    echo "Use --dry-run to output markdown instead" >&2
    exit 1
  fi
  gh pr create --title "$TITLE" --body "$BODY" --base "$BASE"
fi
