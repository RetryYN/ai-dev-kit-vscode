#!/bin/bash
set -euo pipefail
# helix-doctor: 環境チェック
# Usage: helix doctor [--fix]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
FIX=false

case "${1:-}" in
  --fix) FIX=true ;;
  --help|-h)
    echo "使い方: helix doctor [--fix]"
    echo ""
    echo "環境と .helix/ の整合性をチェックします。"
    exit 0
    ;;
  "")
    ;;
  *)
    echo "エラー: 不明なオプション: $1" >&2
    echo "使い方: helix doctor [--fix]" >&2
    exit 1
    ;;
esac

echo "=== HELIX Doctor ==="
PASS=0
FAIL=0
WARN=0
PACKAGE_MANAGER=""

detect_package_manager() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    echo "brew"
    return
  fi

  if [[ -r /etc/os-release ]]; then
    local os_id
    os_id="$(grep -E '^ID=' /etc/os-release | head -n1 | cut -d= -f2 | tr -d '"')"
    case "$os_id" in
      debian|ubuntu)
        echo "apt"
        return
        ;;
      arch|manjaro)
        echo "pacman"
        return
        ;;
    esac
  fi

  echo "unknown"
}

can_auto_fix_with_apt() {
  [[ "$PACKAGE_MANAGER" == "apt" ]] || return 1
  command -v sudo >/dev/null 2>&1 || return 1
  sudo -n true >/dev/null 2>&1
}

install_hint_for() {
  local dep="$1"
  local apt_pkg=""
  local pacman_pkg=""
  local brew_pkg=""

  case "$dep" in
    sqlite3)
      apt_pkg="sqlite3"
      pacman_pkg="sqlite"
      brew_pkg="sqlite"
      ;;
    rg)
      apt_pkg="ripgrep"
      pacman_pkg="ripgrep"
      brew_pkg="ripgrep"
      ;;
    *)
      return 0
      ;;
  esac

  case "$PACKAGE_MANAGER" in
    apt)
      printf '%s\n' "      → インストール: sudo apt install $apt_pkg"
      ;;
    pacman)
      printf '%s\n' "      → インストール: sudo pacman -S --needed $pacman_pkg"
      ;;
    brew)
      printf '%s\n' "      → インストール: brew install $brew_pkg"
      ;;
    *)
      printf '%s\n' \
        "      → インストール候補: sudo apt install $apt_pkg      (Debian/Ubuntu)" \
        "                        sudo pacman -S --needed $pacman_pkg  (Arch/Manjaro)" \
        "                        brew install $brew_pkg             (macOS)"
      ;;
  esac
}

check() {
  local name="$1"
  local cmd="$2"
  local fix_cmd="${3:-}"
  if bash -c "$cmd" >/dev/null 2>&1; then
    echo "  ✓ $name"
    PASS=$((PASS + 1))
  else
    if [[ -n "$fix_cmd" && "$FIX" == true ]]; then
      if bash -c "$fix_cmd" >/dev/null 2>&1; then
        echo "  ✓ $name（自動修正）"
        PASS=$((PASS + 1))
        return
      fi
    fi
    echo "  ✗ $name"
    FAIL=$((FAIL + 1))
  fi
}

warn() {
  local name="$1"
  local cmd="$2"
  local hint="${3:-}"
  local fix_cmd="${4:-}"
  if bash -c "$cmd" >/dev/null 2>&1; then
    echo "  ✓ $name"
    PASS=$((PASS + 1))
  else
    if [[ -n "$fix_cmd" && "$FIX" == true ]]; then
      if bash -c "$fix_cmd" >/dev/null 2>&1; then
        echo "  ✓ $name（自動修正）"
        PASS=$((PASS + 1))
        return
      fi
    fi
    echo "  △ $name（推奨）"
    if [[ -n "$hint" ]]; then
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        echo "$line"
      done <<< "$hint"
    fi
    WARN=$((WARN + 1))
  fi
}

extract_template_version() {
  local file="$1"
  local version=""
  if [[ -f "$file" ]]; then
    version="$(grep -E -m1 'helix_template_version:[[:space:]]*[0-9]+' "$file" | sed -E 's/.*helix_template_version:[[:space:]]*([0-9]+).*/\1/' || true)"
  fi
  if [[ -n "$version" ]]; then
    echo "$version"
  else
    echo "0"
  fi
}

check_template_version() {
  local project_file="$1"
  local template_file="$2"
  local label="$3"
  local project_version template_version
  project_version="$(extract_template_version "$project_file")"
  template_version="$(extract_template_version "$template_file")"

  if [[ "$project_version" == "$template_version" ]]; then
    echo "  ✓ $label テンプレート版数 (v$project_version)"
    PASS=$((PASS + 1))
  else
    echo "  WARN: $label (v$project_version) が古い → テンプレート (v$template_version)。helix init --force で更新可"
    WARN=$((WARN + 1))
  fi
}

echo ""
echo "[必須依存]"
check "python3" "command -v python3"
check "bash 4+" "bash --version | grep -qE 'version [4-9]'"
check "git" "command -v git"

PACKAGE_MANAGER="$(detect_package_manager)"
SQLITE3_HINT="$(install_hint_for sqlite3)"
RG_HINT="$(install_hint_for rg)"
SQLITE3_FIX_CMD=""
RG_FIX_CMD=""
if can_auto_fix_with_apt; then
  SQLITE3_FIX_CMD="sudo apt install -y sqlite3"
  RG_FIX_CMD="sudo apt install -y ripgrep"
fi

echo ""
echo "[推奨依存]"
warn "sqlite3 CLI" "command -v sqlite3" "$SQLITE3_HINT" "$SQLITE3_FIX_CMD"
warn "rg (ripgrep)" "command -v rg" "$RG_HINT" "$RG_FIX_CMD"
warn "codex" "command -v codex"
warn "node" "command -v node"
warn "npm" "command -v npm"

echo ""
echo "[プロジェクト]"
check ".helix/ 存在" "test -d '$HELIX_DIR'" "mkdir -p '$HELIX_DIR'"
check "phase.yaml" "test -f '$HELIX_DIR/phase.yaml'" "'$HELIX_HOME/cli/helix-init' --project-name '$PROJECT_NAME' 2>/dev/null"
check "matrix.yaml" "test -f '$HELIX_DIR/matrix.yaml'"
warn "runtime/index.json" "test -f '$HELIX_DIR/runtime/index.json'" "'$HELIX_HOME/cli/helix-matrix' compile 2>/dev/null"

echo ""
echo "[テンプレート版数]"
check_template_version "$HELIX_DIR/phase.yaml" "$HELIX_HOME/cli/templates/phase.yaml" "phase.yaml"
check_template_version "$HELIX_DIR/gate-checks.yaml" "$HELIX_HOME/cli/templates/gate-checks.yaml" "gate-checks.yaml"
check_template_version "$HELIX_DIR/doc-map.yaml" "$HELIX_HOME/cli/templates/doc-map.yaml" "doc-map.yaml"

echo ""
echo "結果: $PASS pass, $FAIL fail, $WARN warn"
[[ $FAIL -gt 0 ]] && exit 1 || exit 0
