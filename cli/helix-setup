#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix setup <subcommand> [args...]

サブコマンド:
  verify --name <component>     初期化状態を検証
  install --name <component>    初期化に必要な要素を導入
  repair --name <component>     初期化状態を修復
  list                          利用可能 component 一覧
  status [--name <component>]   component 状態を表示
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  verify|install|repair|list|status)
    exec python3 "$SCRIPT_DIR/lib/setup_helper.py" \
      --setup-dir "$SCRIPT_DIR/setup" \
      --project-root "$PROJECT_ROOT" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な setup subcommand: $CMD" >&2
    usage >&2
    exit 2
    ;;
esac
