#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix setup <subcommand> [args...]

サブコマンド:
  verify    初期化状態を検証
  install   初期化に必要な要素を導入
  repair    初期化状態を修復
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  verify|install|repair)
    echo "Sprint X で実装予定 (PLAN-005)"
    exit 0
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な setup subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
