#!/bin/bash
set -eo pipefail

# helix-task: HELIX タスクオペレーティングシステム
# Usage: helix task <catalog|plan|run|status> [args...]

export HELIX_HOME="${HELIX_HOME:-$HOME/ai-dev-kit-vscode}"
SCRIPT_DIR="$HELIX_HOME/cli"
YP="$SCRIPT_DIR/lib/yaml_parser.py"
PROJECT_ROOT="${HELIX_PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
HELIX_DIR="$PROJECT_ROOT/.helix"
CATALOG="$HELIX_HOME/cli/templates/task-catalog.yaml"
TASK_PLAN="$HELIX_DIR/task-plan.yaml"
HELIX_CODEX="$SCRIPT_DIR/helix-codex"
DB_PY="$SCRIPT_DIR/lib/helix_db.py"
DB_PATH="$HELIX_DIR/helix.db"

CMD="${1:-help}"
shift 2>/dev/null || true

# ============================
# catalog: タスクカタログ表示
# ============================
cmd_catalog() {
  local filter="${1:-}"

  python3 -c "
import re, sys

cats = {}
current_cat = None
current_task = None
tasks = {}

with open('$CATALOG') as f:
    for line in f:
        line = line.rstrip()
        if not line or line.lstrip().startswith('#'):
            continue
        # カテゴリ
        m = re.match(r'^(\w[\w-]*):\s*$', line)
        if m:
            name = m.group(1)
            if name not in ('name','input','output','role','estimate','depends','skill'):
                current_cat = name
                cats[current_cat] = []
                continue
        # タスク
        m = re.match(r'  ([\w-]+):\s*$', line)
        if m and current_cat:
            current_task = m.group(1)
            tasks[current_task] = {'cat': current_cat}
            cats[current_cat].append(current_task)
            continue
        # フィールド
        if current_task:
            m = re.match(r'    (\w+):\s*(.+)', line)
            if m:
                tasks[current_task][m.group(1)] = m.group(2).strip('\"')

filt = '$filter'
print('=== HELIX Task Catalog ===')
print()
for cat, task_ids in cats.items():
    if filt and filt != cat and not any(filt in t for t in task_ids):
        continue
    print(f'[{cat}] ({len(task_ids)} tasks)')
    for tid in task_ids:
        t = tasks[tid]
        name = t.get('name', tid)
        role = t.get('role', '?')
        est = t.get('estimate', '?')
        print(f'  {tid:<30s} {role:<12s} ~{est}min  {name}')
    print()
print(f'Total: {sum(len(v) for v in cats.values())} tasks / {len(cats)} categories')
" 2>/dev/null
}

# ============================
# plan: タスクプラン作成
# ============================
cmd_plan() {
  local goal="" task_ids=()

  while [[ $# -gt 0 ]]; do
    case $1 in
      --goal) goal="$2"; shift 2 ;;
      --tasks) IFS=',' read -ra task_ids <<< "$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  if [[ -z "$goal" || ${#task_ids[@]} -eq 0 ]]; then
    echo "Usage: helix task plan --goal '...' --tasks 'research-library,design-api,implement-api,...'" >&2
    exit 1
  fi

  mkdir -p "$HELIX_DIR"

  # タスクプランを生成
  python3 -c "
import re, sys, json
from datetime import date

# カタログ読み込み
cats = {}
current_cat = None
current_task = None
tasks = {}

with open('$CATALOG') as f:
    for line in f:
        line = line.rstrip()
        if not line or line.lstrip().startswith('#'):
            continue
        m = re.match(r'^(\w[\w-]*):\s*$', line)
        if m:
            name = m.group(1)
            if name not in ('name','input','output','role','estimate','depends','skill'):
                current_cat = name
                cats[current_cat] = []
                continue
        m = re.match(r'  ([\w-]+):\s*$', line)
        if m and current_cat:
            current_task = m.group(1)
            tasks[current_task] = {'cat': current_cat}
            cats[current_cat].append(current_task)
            continue
        if current_task:
            m = re.match(r'    (\w+):\s*(.+)', line)
            if m:
                val = m.group(2).strip('\"')
                tasks[current_task][m.group(1)] = val

# タスクプラン生成
selected = [t.strip() for t in '${task_ids[*]}'.split()]
plan_tasks = []
total_estimate = 0

for i, tid in enumerate(selected, 1):
    t = tasks.get(tid, {})
    est = int(t.get('estimate', 0))
    total_estimate += est
    plan_tasks.append({
        'id': f'T{i:03d}',
        'task': tid,
        'name': t.get('name', tid),
        'role': t.get('role', '?'),
        'estimate': est,
        'status': 'pending',
        'skill': t.get('skill', ''),
    })

# YAML 出力
lines = [
    f'# Task Plan — {date.today()}',
    f'goal: \"$goal\"',
    f'total_estimate: {total_estimate}',
    f'status: active',
    f'tasks:',
]
for t in plan_tasks:
    lines.append(f'  {t[\"id\"]}:')
    lines.append(f'    task: {t[\"task\"]}')
    lines.append(f'    name: \"{t[\"name\"]}\"')
    lines.append(f'    role: {t[\"role\"]}')
    lines.append(f'    estimate: {t[\"estimate\"]}')
    lines.append(f'    status: pending')
    lines.append(f'    skill: {t[\"skill\"]}')

with open('$TASK_PLAN', 'w') as f:
    f.write('\n'.join(lines) + '\n')

print(f'=== Task Plan: $goal ===')
print()
print(f'Total: {len(plan_tasks)} tasks, ~{total_estimate} min')
print()
for t in plan_tasks:
    print(f'  {t[\"id\"]} [{t[\"role\"]:<12s}] ~{t[\"estimate\"]:>3d}min  {t[\"name\"]}')
print()
print(f'Saved: $TASK_PLAN')
" 2>/dev/null

  # === タスク選択を DB に記録 ===
  if [[ -f "$DB_PATH" ]]; then
    local plan_id
    plan_id="plan-$(date '+%Y%m%d-%H%M%S')"
    local all_tasks
    all_tasks=$(python3 -c "
import re
tasks = []
current_cat = None
with open('$CATALOG') as f:
    for line in f:
        m = re.match(r'  ([\w-]+):\s*$', line.rstrip())
        if m:
            name = m.group(1)
            if name not in ('name','role','estimate','skill','actions'):
                tasks.append(name)
import json; print(json.dumps(tasks))
" 2>/dev/null)

    python3 "$DB_PY" record-selection "$DB_PATH" "$(python3 -c "
import json
print(json.dumps({
    'plan_id': '$plan_id',
    'plan_goal': '$goal',
    'selected_tasks': '${task_ids[*]}'.split(),
    'available_tasks': json.loads('$all_tasks')
}))
" 2>/dev/null)" 2>/dev/null

    local sel_id
    sel_id=$(python3 -c "
import sqlite3
conn = sqlite3.connect('$DB_PATH')
row = conn.execute('SELECT id FROM task_selections ORDER BY id DESC LIMIT 1').fetchone()
print(row[0] if row else '')
conn.close()
" 2>/dev/null)

    echo ""
    echo "[helix-task] タスク選択を DB に記録 (selection #$sel_id)"

    # === TL レビュー自動発火 ===
    echo "[helix-task] TL レビューを実行中..."
    echo ""

    local review_prompt="タスクプランレビュー:

ゴール: $goal
選択タスク: ${task_ids[*]}

以下の観点でレビューせよ:
1. タスクの過不足（足りないタスクはないか、不要なタスクはないか）
2. タスクの順序（依存関係が正しいか）
3. ロール割当（適切なロールか）
4. リスク（セキュリティレビューや検証が抜けていないか）

結果を判定(approved/rejected)とともに、追加すべきタスク・削除すべきタスクの提案を返せ。"

    set +e
    local review_result
    review_result=$("$HELIX_CODEX" --role tl --task "$review_prompt" 2>&1)
    set -e

    # レビュー結果をDB に記録
    local review_status="approved"
    echo "$review_result" | grep -qi "reject\|不足\|追加すべき\|missing" && review_status="revised"

    python3 "$DB_PY" update-review "$DB_PATH" "$(python3 -c "
import json
print(json.dumps({
    'selection_id': $sel_id,
    'review_status': '$review_status',
    'review_result': '''$(echo "$review_result" | tail -20 | head -c 500)''',
    'review_suggestions': ''
}))
" 2>/dev/null)" 2>/dev/null

    echo ""
    echo "[helix-task] TL レビュー: $review_status"
    if [[ "$review_status" == "revised" ]]; then
      echo "[helix-task] TL から修正提案があります。内容を確認してください。"
    fi
    echo ""
  fi

  echo "Next: helix task run"
}

# ============================
# run: 次のタスクを実行
# ============================
cmd_run() {
  if [[ ! -f "$TASK_PLAN" ]]; then
    echo "Error: タスクプランがありません。'helix task plan' で作成してください。" >&2
    exit 1
  fi

  # 次の pending タスクを取得
  local next_task
  next_task=$(python3 -c "
import re
current_id = None
current_task = None
current_role = None
current_name = None
current_skill = None

with open('$TASK_PLAN') as f:
    for line in f:
        line = line.rstrip()
        m = re.match(r'  (T\d+):', line)
        if m:
            current_id = m.group(1)
            continue
        if current_id:
            m = re.match(r'    (\w+):\s*(.+)', line)
            if m:
                key, val = m.group(1), m.group(2).strip('\"')
                if key == 'task': current_task = val
                elif key == 'role': current_role = val
                elif key == 'name': current_name = val
                elif key == 'skill': current_skill = val
                elif key == 'status' and val == 'pending':
                    print(f'{current_id}|{current_task}|{current_role}|{current_name}|{current_skill}')
                    exit()
" 2>/dev/null)

  if [[ -z "$next_task" ]]; then
    echo "=== All tasks completed ==="
    exit 0
  fi

  IFS='|' read -r tid task_type role name skill <<< "$next_task"

  echo "=== $tid: $name ==="
  echo "Task: $task_type"
  echo "Role: $role"
  echo "Skill: $skill"
  echo ""

  # ステータスを running に
  sed -i "/$tid:/,/status:/{s/status: pending/status: running/}" "$TASK_PLAN" 2>/dev/null

  # DB 記録（DB がある場合）
  local db_run_id=""
  if [[ -f "$DB_PATH" ]]; then
    local plan_goal
    plan_goal=$(grep '^goal:' "$TASK_PLAN" 2>/dev/null | sed 's/goal: *"*//' | sed 's/"*$//' || echo "")
    db_run_id=$(python3 "$DB_PY" record-task "$DB_PATH" "$(python3 -c "
import json; print(json.dumps({
    'task_id': '$tid', 'task_type': '$task_type',
    'plan_goal': '$plan_goal', 'role': '$role', 'status': 'running'
}))" 2>/dev/null)" 2>/dev/null || echo "")
  fi

  # ログディレクトリ
  local LOG_DIR="$HELIX_DIR/task-logs"
  mkdir -p "$LOG_DIR"
  local LOG_FILE="$LOG_DIR/${tid}-${task_type}.log"

  # ロールに応じて実行（出力をログに保存）
  if [[ "$task_type" == "review-visual" ]]; then
    # ビジュアルレビュー: スクショを Claude に読ませる
    echo "[helix-task] ビジュアルレビュー実行"
    echo ""

    local VISUAL_CHECK_DIR="$HELIX_DIR/visual-checks"
    local screenshots=()
    for ss_dir in "$VISUAL_CHECK_DIR"/*-screenshots/; do
      [[ -d "$ss_dir" ]] || continue
      for img in "$ss_dir"*.png; do
        [[ -f "$img" ]] && screenshots+=("$img")
      done
    done

    if [[ ${#screenshots[@]} -eq 0 ]]; then
      echo "[helix-task] スクリーンショットが見つかりません" | tee "$LOG_FILE"
      echo "  先に UI タスクを実行してスクショを撮影してください"
    else
      echo "  レビュー対象: ${#screenshots[@]} 枚"
      for ss in "${screenshots[@]}"; do
        echo "    $(basename "$ss")"
      done
      echo ""

      # Claude に画像を読ませてレビュー（Read ツールは画像対応）
      local review_prompt="ビジュアルレビュー:

以下のスクリーンショットを確認し、UIデザインの品質をレビューせよ。

スクリーンショット:"
      for ss in "${screenshots[@]}"; do
        review_prompt+="
- $ss"
      done
      review_prompt+="

レビュー観点:
1. レイアウトの崩れ・意図しない余白
2. テキストの切れ・はみ出し
3. 配色の一貫性（ベース/メイン/アクセントの比率）
4. フォントサイズ・ウェイトの適切さ
5. ボタン・入力フィールドのサイズ・タップ領域
6. コントラスト比（アクセシビリティ）
7. desktop/tablet/mobile 間の一貫性

各スクリーンショットを Read して目視確認し、指摘事項を出力せよ。
指摘がなければ「問題なし」と明記。
最後に判定: approved / needs-fix を出力。"

      echo "[helix-task] @fe-design にスクショレビューを委譲してください:"
      echo ""
      echo "  @fe-design $review_prompt"
      echo ""
      echo "$review_prompt" > "$LOG_FILE"

      # 確認記録を更新
      for check_md in "$VISUAL_CHECK_DIR"/*.md; do
        [[ -f "$check_md" ]] || continue
        if grep -q "判定: pending" "$check_md" 2>/dev/null; then
          sed -i 's/判定: pending/判定: reviewing/' "$check_md"
        fi
      done
      echo "[helix-task] 確認記録を reviewing に更新"
      echo "  → レビュー結果に基づき approved / needs-fix に変更してください"
    fi
  elif [[ "$role" == fe-design || "$role" == fe-component || "$role" == fe-style || "$role" == fe-a11y || "$role" == fe-test ]]; then
    echo "[helix-task] Claude サブエージェント @$role に委譲してください"
    echo "  @$role $name"
    echo "[agent-delegation] @$role $name" > "$LOG_FILE"
  else
    echo "[helix-task] helix-codex --role $role に委譲"
    set +e
    "$HELIX_CODEX" --role "$role" --task "$name" 2>&1 | tee "$LOG_FILE"
    set -e
  fi

  # UI 系タスクの目視確認チェック
  local UI_TASKS="implement-ui-component implement-style design-ui"
  local needs_visual_check=false
  for ui_task in $UI_TASKS; do
    [[ "$task_type" == "$ui_task" ]] && needs_visual_check=true
  done

  if [[ "$needs_visual_check" == true ]]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  UI 目視確認が必要です"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    local VISUAL_CHECK_DIR="$HELIX_DIR/visual-checks"
    local SCREENSHOT_DIR="$VISUAL_CHECK_DIR/${tid}-screenshots"
    mkdir -p "$SCREENSHOT_DIR"
    local check_file="$VISUAL_CHECK_DIR/${tid}-${task_type}.md"

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  UI 目視確認が必要です"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  スクリーンショットを撮影して以下に保存してください:"
    echo "    $SCREENSHOT_DIR/"
    echo ""
    echo "  必須スクリーンショット:"
    echo "    desktop.png   — デスクトップ表示 (1280px+)"
    echo "    tablet.png    — タブレット表示 (768px)"
    echo "    mobile.png    — モバイル表示 (375px)"
    echo ""
    echo "  任意:"
    echo "    dark.png      — ダークモード"
    echo "    hover.png     — ホバー/インタラクション状態"
    echo "    error.png     — エラー状態"
    echo ""
    echo "  撮影方法:"
    echo "    ブラウザ DevTools → Toggle device → Screenshot"
    echo "    または: npx playwright screenshot --url http://localhost:3000 --path $SCREENSHOT_DIR/desktop.png"
    echo ""

    cat > "$check_file" << VCHECK
# UI 目視確認: $tid — $name
# Date: $(date '+%Y-%m-%d %H:%M')

## スクリーンショット
- desktop.png: [ ] 撮影済み
- tablet.png:  [ ] 撮影済み
- mobile.png:  [ ] 撮影済み

## 確認結果
- [ ] デザインカンプとの一致
- [ ] レスポンシブ崩れなし
- [ ] デザイントークン準拠（色・フォント・余白）
- [ ] アクセシビリティ（コントラスト・フォーカス）

## 指摘事項
-

## 判定: pending
VCHECK

    echo "  確認記録: $check_file"
    echo "  → スクリーンショット 3 枚 + 判定を approved に変更で G5 通過可能"
    echo ""
  fi

  # ステータスを completed に
  sed -i "/$tid:/,/status:/{s/status: running/status: completed/}" "$TASK_PLAN" 2>/dev/null

  # DB 更新
  if [[ -f "$DB_PATH" && -n "$db_run_id" ]]; then
    python3 -c "
import sqlite3
from datetime import datetime
conn = sqlite3.connect('$DB_PATH')
conn.execute('UPDATE task_runs SET status=?, completed_at=?, output_log=? WHERE id=?',
    ('completed', datetime.now().isoformat(), '$LOG_FILE', $db_run_id))
conn.commit()
conn.close()
" 2>/dev/null || true
  fi

  echo ""
  echo "[helix-task] $tid 完了。ログ: $LOG_FILE"
  echo "[helix-task] 'helix task observe $tid' で品質検証"
  echo "[helix-task] 'helix task run' で次のタスクを実行"
}

# ============================
# status: タスクプラン状態表示
# ============================
cmd_status() {
  if [[ ! -f "$TASK_PLAN" ]]; then
    echo "タスクプランがありません。" >&2
    exit 1
  fi

  python3 -c "
import re

goal = ''
total = 0
tasks = []
current = {}

with open('$TASK_PLAN') as f:
    for line in f:
        line = line.rstrip()
        m = re.match(r'goal:\s*\"?(.+?)\"?\s*$', line)
        if m: goal = m.group(1)
        m = re.match(r'  (T\d+):', line)
        if m:
            if current: tasks.append(current)
            current = {'id': m.group(1)}
            continue
        if current:
            m = re.match(r'    (\w+):\s*(.+)', line)
            if m:
                current[m.group(1)] = m.group(2).strip('\"')
    if current: tasks.append(current)

done = sum(1 for t in tasks if t.get('status') == 'completed')
running = sum(1 for t in tasks if t.get('status') == 'running')
pending = sum(1 for t in tasks if t.get('status') == 'pending')
total_est = sum(int(t.get('estimate', 0)) for t in tasks)

print(f'=== Task Plan: {goal} ===')
print(f'Progress: {done}/{len(tasks)} completed, {running} running, {pending} pending')
print(f'Estimate: ~{total_est} min')
print()
for t in tasks:
    status = t.get('status', '?')
    icon = {'completed':'✓', 'running':'→', 'pending':' '}.get(status, '?')
    role = t.get('role', '?')
    name = t.get('name', t.get('task', '?'))
    est = t.get('estimate', '?')
    print(f'  {icon} {t[\"id\"]} [{role:<12s}] ~{est:>3s}min  {name}')
" 2>/dev/null
}

# ============================
# observe: タスク実行結果の品質検証
# ============================
cmd_observe() {
  local target="${1:-all}"
  local LOG_DIR="$HELIX_DIR/task-logs"
  local ACTION_TYPES="$HELIX_HOME/cli/templates/action-types.yaml"

  if [[ ! -d "$LOG_DIR" ]]; then
    echo "ログなし。'helix task run' でタスクを実行してください。" >&2
    exit 1
  fi

  python3 -c "
import re, sys, os

# アクション型のオブザーバールール読み込み
action_rules = {}
current_type = None
current_keywords = []
with open('$ACTION_TYPES') as f:
    for line in f:
        line = line.rstrip()
        if not line or line.lstrip().startswith('#'):
            continue
        m = re.match(r'^([\w-]+):\s*$', line)
        if m:
            if current_type and current_keywords:
                action_rules[current_type] = current_keywords
            current_type = m.group(1)
            current_keywords = []
            continue
        m = re.match(r'\s+expect_keywords:\s*\[(.+)\]', line)
        if m and current_type:
            current_keywords = [k.strip().strip('\"') for k in m.group(1).split(',')]
    if current_type and current_keywords:
        action_rules[current_type] = current_keywords

# タスクカタログからアクション列読み込み
task_actions = {}
current_task = None
with open('$CATALOG') as f:
    for line in f:
        line = line.rstrip()
        m = re.match(r'  ([\w-]+):\s*$', line)
        if m:
            name = m.group(1)
            if name not in ('name','role','estimate','skill','actions'):
                current_task = name
                task_actions[current_task] = []
                continue
        if current_task and '{ type:' in line:
            m = re.search(r'type:\s*([\w-]+)', line)
            dm = re.search(r'desc:\s*\"?(.+?)\"?\s*\}', line)
            if m:
                task_actions[current_task].append({
                    'type': m.group(1),
                    'desc': dm.group(1) if dm else ''
                })

# ログファイルを検証
log_dir = '$LOG_DIR'
target = '$target'
total_actions = 0
passed_actions = 0
failed_actions = 0
results = []

for log_file in sorted(os.listdir(log_dir)):
    if not log_file.endswith('.log'):
        continue
    tid = log_file.split('-')[0]
    task_type = '-'.join(log_file.split('-')[1:]).replace('.log', '')

    if target != 'all' and target != tid:
        continue

    log_path = os.path.join(log_dir, log_file)
    log_content = open(log_path).read()

    actions = task_actions.get(task_type, [])
    if not actions:
        results.append((tid, task_type, 'SKIP', 'No actions defined', []))
        continue

    action_results = []
    task_pass = 0
    task_fail = 0

    for action in actions:
        atype = action['type']
        desc = action['desc']
        keywords = action_rules.get(atype, [])

        if not keywords:
            action_results.append(('—', atype, desc, 'no rules'))
            continue

        matched = any(kw.lower() in log_content.lower() for kw in keywords)
        total_actions += 1
        if matched:
            passed_actions += 1
            task_pass += 1
            action_results.append(('✓', atype, desc, ''))
        else:
            failed_actions += 1
            task_fail += 1
            action_results.append(('✗', atype, desc, f'expected: {keywords[:3]}'))

    status = 'PASS' if task_fail == 0 else f'FAIL ({task_fail} actions)'
    results.append((tid, task_type, status, f'{task_pass}/{task_pass+task_fail}', action_results))

# 出力
print('=== Task Observation Report ===')
print()
for tid, task_type, status, summary, action_results in results:
    icon = '✓' if 'PASS' in status else ('—' if 'SKIP' in status else '✗')
    print(f'{icon} {tid} {task_type}: {status} ({summary})')
    if action_results and 'FAIL' in status:
        for aicon, atype, desc, note in action_results:
            if aicon == '✗':
                print(f'    {aicon} [{atype}] {desc}')
                if note:
                    print(f'      → {note}')
    print()

print(f'=== Summary: {passed_actions}/{total_actions} actions passed, {failed_actions} failed ===')
if failed_actions > 0:
    sys.exit(1)
" 2>/dev/null
}

