#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix lock <subcommand> [args...]

サブコマンド:
  acquire   DB lock を取得
  release   DB lock を解放
  list      DB lock 一覧を表示
  status    DB lock 状態を表示
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  acquire|release|list|status)
    echo "Sprint X で実装予定 (PLAN-005)"
    exit 0
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な lock subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
