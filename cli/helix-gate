#!/bin/bash
set -eo pipefail

# helix-gate: HELIX ゲート自動検証
# Usage: helix-gate <gate-name> [--static-only] [--ai-only] [--dry-run]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="${HELIX_PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
HELIX_DIR="$PROJECT_ROOT/.helix"
GATE_CHECKS="$HELIX_DIR/gate-checks.yaml"
PHASE_FILE="$HELIX_DIR/phase.yaml"
HELIX_CODEX="$SCRIPT_DIR/helix-codex"

# --- 引数パース ---
GATE=""
STATIC_ONLY=false
AI_ONLY=false
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --static-only) STATIC_ONLY=true; shift ;;
    --ai-only)     AI_ONLY=true; shift ;;
    --dry-run)     DRY_RUN=true; shift ;;
    --help|-h)
      echo "Usage: helix-gate <gate> [--static-only] [--ai-only] [--dry-run]"
      echo ""
      echo "Gates: G2, G3, G4, G5, G6, G7"
      exit 0
      ;;
    *)
      if [[ -z "$GATE" ]]; then
        GATE="$1"; shift
      else
        echo "Error: Unknown option: $1" >&2; exit 1
      fi
      ;;
  esac
done

if [[ -z "$GATE" ]]; then
  echo "Error: Gate name required (G2, G3, G4, G5, G6, G7)" >&2
  exit 1
fi

if [[ ! "$GATE" =~ ^G[2-7]$ ]]; then
  echo "Error: Invalid gate: $GATE (must be G2-G7)" >&2
  exit 1
fi

if [[ ! -f "$GATE_CHECKS" ]]; then
  echo "Error: $GATE_CHECKS not found. Run 'helix-init' to set up." >&2
  exit 1
fi

# --- ゲート前提条件チェック ---
declare -A GATE_PREREQS=(
  ["G2"]=""
  ["G3"]="G2"
  ["G4"]="G3"
  ["G5"]="G4"
  ["G6"]="G5"
  ["G7"]="G6"
)

YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
DELIVERABLE_GATE="$SCRIPT_DIR/lib/deliverable_gate.py"

prereq="${GATE_PREREQS[$GATE]:-}"
if [[ -n "$prereq" && -f "$PHASE_FILE" && -f "$YAML_PARSER" ]]; then
  prereq_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "gates.${prereq}.status" 2>/dev/null || echo "pending")
  if [[ "$prereq_status" != "passed" && "$prereq_status" != "skipped" ]]; then
    echo "Error: 前提ゲート $prereq が未通過 (status: $prereq_status)" >&2
    echo "$prereq を先に通過させてください" >&2
    exit 1
  fi
fi

# --- ゲート名を取得 ---
gate_name=$(grep -A1 "^${GATE}:" "$GATE_CHECKS" | grep 'name:' | sed 's/.*name: *"//' | sed 's/"//' || echo "$GATE")

echo ""
echo "=== $GATE: $gate_name ==="
echo ""

# 実際の実行はここから
run_checks() {
  local gate="$1"
  local deliv_fail=0
  local static_pass=0
  local static_fail=0
  local static_skip=0
  local ai_pass=0
  local ai_fail=0

  # --- Deliverable Check ---
  local index_file="$HELIX_DIR/runtime/index.json"
  local state_file="$HELIX_DIR/state/deliverables.json"
  if [[ -f "$index_file" && -f "$state_file" ]]; then
    echo "[deliverable]"
    if python3 "$DELIVERABLE_GATE" --index "$index_file" --state "$state_file" --gate "$gate"; then
      echo ""
    else
      deliv_fail=1
      echo ""
    fi
  fi

  # --- Fullstack Twin Track Check ---
  if [[ -f "$PHASE_FILE" ]]; then
    local drive
    drive=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.drive" 2>/dev/null || echo "")
    if [[ "$drive" == "fullstack" && ("$gate" == "G3" || "$gate" == "G4") ]]; then
      echo "[fullstack]"
      # G4: BE/FE 両 track の stage が .5 かつ status が completed であること
      if [[ "$gate" == "G4" ]]; then
        local be_stage fe_stage contract_ci be_status fe_status
        be_stage=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.be.stage" 2>/dev/null || echo "")
        fe_stage=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.fe.stage" 2>/dev/null || echo "")
        be_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.be.status" 2>/dev/null || echo "")
        fe_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.fe.status" 2>/dev/null || echo "")
        contract_ci=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.contract.ci" 2>/dev/null || echo "")

        local twin_fail=0
        if [[ "$be_stage" != ".5" || "$be_status" != "completed" ]]; then
          echo "  FAIL: BE Track 未完了 (stage=$be_stage, status=$be_status)"
          twin_fail=1
        fi
        if [[ "$fe_stage" != ".5" || "$fe_status" != "completed" ]]; then
          echo "  FAIL: FE Track 未完了 (stage=$fe_stage, status=$fe_status)"
          twin_fail=1
        fi
        if [[ "$contract_ci" != "pass" ]]; then
          echo "  FAIL: Contract CI 未通過 (ci=$contract_ci)"
          twin_fail=1
        fi
        if [[ $twin_fail -gt 0 ]]; then
          deliv_fail=$((deliv_fail + twin_fail))
          echo "  fullstack G4: FAIL"
        else
          echo "  fullstack G4: BE .5 ✓ FE .5 ✓ Contract CI ✓"
        fi
        echo ""
      fi
    fi
  fi

  if [[ "$AI_ONLY" != true ]]; then
    echo "[static]"

    # gate-checks.yaml からこのゲートの static チェックを抽出・実行
    local in_gate=false
    local in_static=false
    local check_name=""
    local check_cmd=""

    while IFS= read -r line; do
      if [[ "$line" =~ ^${gate}:[[:space:]]*$ ]]; then
        in_gate=true
        continue
      fi
      # 次のゲート定義に入ったら終了
      if [[ "$in_gate" == true ]] && echo "$line" | grep -qE '^[A-Z][0-9]+:'; then
        break
      fi
      if [[ "$in_gate" == true && "$line" =~ ^[[:space:]]+static: ]]; then
        in_static=true
        continue
      fi
      if [[ "$in_gate" == true && "$in_static" == true ]]; then
        # ai: セクションに入ったら static 終了
        if [[ "$line" =~ ^[[:space:]]+ai: ]]; then
          # 残りのチェックを実行
          if [[ -n "$check_cmd" ]]; then
            if [[ "$DRY_RUN" == true ]]; then
              echo "  [dry-run] $check_name: $check_cmd"
            else
              if (cd "$PROJECT_ROOT" && bash -c "$check_cmd") >/dev/null 2>&1; then
                echo "  PASS: $check_name"
                static_pass=$((static_pass + 1))
              else
                echo "  FAIL: $check_name"
                echo "    cmd: $check_cmd"
                static_fail=$((static_fail + 1))
              fi
            fi
          fi
          in_static=false
          continue
        fi
        if [[ "$line" =~ name:[[:space:]]*\"(.+)\" ]]; then
          # 前のチェックを実行
          if [[ -n "$check_cmd" ]]; then
            if [[ "$DRY_RUN" == true ]]; then
              echo "  [dry-run] $check_name: $check_cmd"
            else
              if (cd "$PROJECT_ROOT" && bash -c "$check_cmd") >/dev/null 2>&1; then
                echo "  PASS: $check_name"
                static_pass=$((static_pass + 1))
              else
                echo "  FAIL: $check_name"
                echo "    cmd: $check_cmd"
                static_fail=$((static_fail + 1))
              fi
            fi
          fi
          check_name="${BASH_REMATCH[1]}"
          check_cmd=""
        elif [[ "$line" =~ cmd:[[:space:]]*\"(.+)\" ]]; then
          check_cmd="${BASH_REMATCH[1]}"
        fi
      fi
    done < "$GATE_CHECKS"

    # 最後のチェック
    if [[ "$in_static" == true && -n "$check_cmd" ]]; then
      if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] $check_name: $check_cmd"
      else
        if (cd "$PROJECT_ROOT" && bash -c "$check_cmd") >/dev/null 2>&1; then
          echo "  PASS: $check_name"
          static_pass=$((static_pass + 1))
        else
          echo "  FAIL: $check_name"
          echo "    cmd: $check_cmd"
          static_fail=$((static_fail + 1))
        fi
      fi
    fi

    if [[ $((static_pass + static_fail)) -eq 0 ]]; then
      echo "  (static チェックなし)"
    else
      echo ""
      echo "  static: $static_pass pass, $static_fail fail"
    fi
    echo ""
  fi

  # --- AI チェック ---
  if [[ "$STATIC_ONLY" != true ]]; then
    echo "[ai]"

    local in_gate=false
    local in_ai=false
    local ai_role=""
    local ai_task=""
    local ai_count=0

    run_ai_check() {
      local role="$1"
      local task="$2"

      ai_count=$((ai_count + 1))
      if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] helix-codex --role $role --task \"${task:0:60}...\""
        return
      fi

      echo "  実行中: helix-codex --role $role ..."
      local ai_output_file
      ai_output_file=$(mktemp "${TMPDIR:-/tmp}/helix-gate-ai-XXXXXX")

      set +e
      "$HELIX_CODEX" --role "$role" --task "$task" >"$ai_output_file" 2>&1
      local ai_exit=$?
      set -e

      cat "$ai_output_file"

      local verdict=""
      verdict=$(grep -Eo '"verdict"[[:space:]]*:[[:space:]]*"(approve|needs-attention)"' "$ai_output_file" | head -n1 | sed -E 's/.*"(approve|needs-attention)"/\1/' || true)

      if [[ "$verdict" == "needs-attention" ]]; then
        ai_fail=$((ai_fail + 1))
        echo "  [ai] FAIL: $role (verdict: needs-attention)"
      elif [[ -n "$verdict" ]]; then
        ai_pass=$((ai_pass + 1))
      elif [[ "$ai_exit" -eq 0 ]]; then
        ai_pass=$((ai_pass + 1))
      else
        ai_fail=$((ai_fail + 1))
        echo "  [ai] FAIL: $role"
      fi

      rm -f "$ai_output_file"
      echo ""
    }

    while IFS= read -r line; do
      if [[ "$line" =~ ^${gate}:[[:space:]]*$ ]]; then
        in_gate=true
        continue
      fi
      if [[ "$in_gate" == true ]] && echo "$line" | grep -qE '^[A-Z][0-9]+:'; then
        break
      fi
      if [[ "$in_gate" == true && "$line" =~ ^[[:space:]]+ai: ]]; then
        in_ai=true
        continue
      fi
      if [[ "$in_ai" == true ]]; then
        if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*role:[[:space:]]*(.+) ]]; then
          # 前の AI チェックを実行
          if [[ -n "$ai_role" && -n "$ai_task" ]]; then
            run_ai_check "$ai_role" "$ai_task"
          fi
          ai_role="${BASH_REMATCH[1]}"
          ai_task=""
        elif [[ "$line" =~ task:[[:space:]]*\|[[:space:]]*$ ]]; then
          # multiline task 開始
          ai_task=""
        elif [[ "$in_ai" == true && -n "$ai_role" && "$line" =~ ^[[:space:]]{8} ]]; then
          # multiline task の続き
          ai_task+="${line#        }"$'\n'
        fi
      fi
    done < "$GATE_CHECKS"

    # 最後の AI チェック
    if [[ -n "$ai_role" && -n "$ai_task" ]]; then
      run_ai_check "$ai_role" "$ai_task"
    fi

    if [[ $ai_count -eq 0 ]]; then
      echo "  (AI チェックなし)"
    else
      echo "  ai: $ai_pass pass, $ai_fail fail"
    fi
  fi

  # --- 総合判定 ---
  local total_fail=$((deliv_fail + static_fail + ai_fail))
  echo ""
  if [[ $total_fail -gt 0 ]]; then
    echo "=== $gate FAIL (deliverable: $deliv_fail fail, static: $static_fail fail, ai: $ai_fail fail) ==="
    if [[ "$DRY_RUN" != true && -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.status" "failed" 2>/dev/null || true
    fi
    exit 1
  else
    echo "=== $gate PASS ==="
    if [[ "$DRY_RUN" != true && -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.status" "passed" 2>/dev/null || true
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.date" "$(date '+%Y-%m-%d')" 2>/dev/null || true
      maybe_generate_retro "$gate"
    fi
  fi
}

# --- ミニレトロ自動生成 ---
maybe_generate_retro() {
  local gate="$1"
  local phase_desc=""

  case "$gate" in
    G2) phase_desc="設計フェーズ (L1-L2)" ;;
    G4) phase_desc="実装フェーズ (L3-L4)" ;;
    *)  return ;;
  esac

  local retro_dir="$HELIX_DIR/retros"
  mkdir -p "$retro_dir"
  local today
  today=$(date '+%Y-%m-%d')
  local retro_file="$retro_dir/${today}-${gate}.md"

  if [[ -f "$retro_file" ]]; then
    echo ""
    echo "[helix-gate] Retro already exists: $retro_file"
    return
  fi

  local template="$SCRIPT_DIR/templates/retro.md.template"
  if [[ -f "$template" ]]; then
    sed -e "s/{{GATE}}/$gate/g" \
        -e "s/{{DATE}}/$today/g" \
        -e "s/{{PHASE_DESC}}/$phase_desc/g" \
        "$template" > "$retro_file"
  else
    cat > "$retro_file" <<RETRO
# Mini Retro: $gate ($today)

## Phase: $phase_desc

### Keep（うまくいったこと）
-

### Problem（問題があったこと）
-

### Try（次に試すこと）
| アクション | 担当 | 期日 |
|-----------|------|------|
| | | |
RETRO
  fi

  echo ""
  echo "[helix-gate] ミニレトロ生成: $retro_file"
  echo "[helix-gate]   内容を記入してください（Try は owner + due 必須）"
}

run_checks "$GATE"
