#!/bin/bash
set -eo pipefail

# helix-gate: HELIX ゲート自動検証
# Usage: helix-gate <gate-name> [--static-only] [--ai-only] [--dry-run]
#
# 責務分離:
#   1. 前提条件チェック（prereq gate）      → check_prerequisites()
#   2. Deliverable チェック                 → deliverable_gate.py
#   3. Static チェック                      → gate-checks.yaml 実行
#   4. AI チェック                          → helix-codex 委譲
#   5. 総合判定 + phase.yaml 更新           → update_phase()
#   6. 後処理（retro 生成、提案メッセージ）  → post_gate()

export HELIX_HOME="${HELIX_HOME:-$HOME/ai-dev-kit-vscode}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="${HELIX_PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
HELIX_DIR="$PROJECT_ROOT/.helix"
GATE_CHECKS="$HELIX_DIR/gate-checks.yaml"
PHASE_FILE="$HELIX_DIR/phase.yaml"
HELIX_CODEX="$SCRIPT_DIR/helix-codex"

# --- 引数パース ---
GATE=""
STATIC_ONLY=false
AI_ONLY=false
DRY_RUN=false
UNDO=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --static-only) STATIC_ONLY=true; shift ;;
    --ai-only)     AI_ONLY=true; shift ;;
    --dry-run)     DRY_RUN=true; shift ;;
    --undo)        UNDO=true; shift ;;
    --help|-h)
      echo "使い方: helix gate <gate> [--static-only] [--ai-only] [--dry-run] [--undo]"
      echo ""
      echo "Gates: G0.5, G2, G3, G4, G5, G6, G7"
      exit 0
      ;;
    *)
      if [[ -z "$GATE" ]]; then
        GATE="$1"; shift
      else
        echo "エラー: 不明なオプションです: $1" >&2; exit 1
      fi
      ;;
  esac
done

if [[ -z "$GATE" ]]; then
  echo "エラー: ゲート名が必要です（G0.5, G2, G3, G4, G5, G6, G7）" >&2
  exit 1
fi

if [[ ! "$GATE" =~ ^G(0\.5|[2-7])$ ]]; then
  echo "エラー: 無効なゲートです: $GATE（G0.5, G2-G7 を指定してください）" >&2
  exit 1
fi

# --- ゲート前提条件チェック ---
declare -A GATE_PREREQS=(
  ["G0.5"]=""
  ["G2"]="G1"
  ["G3"]="G2"
  ["G4"]="G3"
  ["G5"]="G4"
  ["G6"]="G5"
  ["G7"]="G6"
)

YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
DELIVERABLE_GATE="$SCRIPT_DIR/lib/deliverable_gate.py"

if [[ "$UNDO" == true ]]; then
  if [[ ! -f "$PHASE_FILE" ]]; then
    echo "エラー: $PHASE_FILE が見つかりません。'helix-init' を実行してください。" >&2
    exit 1
  fi
  python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.status" "pending" 2>/dev/null || true
  python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.date" "" 2>/dev/null || true
  echo "=== $GATE を pending に戻しました ==="
  exit 0
fi

if [[ ! -f "$GATE_CHECKS" ]]; then
  echo "エラー: $GATE_CHECKS が見つかりません。'helix-init' を実行してください。" >&2
  exit 1
fi

now_ms() {
  local ms
  ms=$(date +%s%3N 2>/dev/null || true)
  if [[ -z "$ms" ]]; then
    ms=$(( $(date +%s) * 1000 ))
  fi
  echo "$ms"
}

log_gate_run() {
  local gate="$1"
  local result="$2"
  local deliv_fail="$3"
  local static_fail="$4"
  local ai_fail="$5"
  local duration_ms="$6"
  local payload
  payload="{\"gate\":\"$gate\",\"result\":\"$result\",\"fail_reasons\":\"deliverable:$deliv_fail,static:$static_fail,ai:$ai_fail\",\"duration_ms\":$duration_ms}"
  HELIX_DB_PATH="$HELIX_DIR/helix.db" python3 "$SCRIPT_DIR/lib/helix_db.py" insert gate_runs "$payload" 2>/dev/null || true
}

prereq="${GATE_PREREQS[$GATE]:-}"
if [[ -n "$prereq" && -f "$PHASE_FILE" && -f "$YAML_PARSER" ]]; then
  prereq_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "gates.${prereq}.status" 2>/dev/null || echo "pending")
  if [[ "$prereq_status" != "passed" && "$prereq_status" != "skipped" ]]; then
    echo "エラー: 前提ゲート $prereq が未通過です (status: $prereq_status)" >&2
    echo "$prereq を先に通過させてください" >&2
    exit 1
  fi
fi

# --- ゲート名を取得 ---
gate_name=$(
  awk -v gate="$GATE" '
    {
      line = $0
      sub(/[[:space:]]+$/, "", line)
    }
    line == gate ":" {
      in_gate = 1
      next
    }
    in_gate && match($0, /name:[[:space:]]*"([^"]+)"/, m) {
      print m[1]
      exit
    }
    in_gate && line ~ /^G[0-9]+([.][0-9]+)?[A-Z]?:$/ {
      exit
    }
  ' "$GATE_CHECKS"
)
gate_name="${gate_name:-$GATE}"

echo ""
echo "=== $GATE: $gate_name ==="
echo ""

if [[ "$GATE" == "G7" ]]; then
  echo "[helix-gate] デプロイ前チェックリスト:"
  echo "  □ staging 環境でのスモークテスト完了"
  echo "  □ ロールバック手順の確認"
  echo "  □ DB マイグレーションの rehearsal 完了"
  echo "  □ 監視ダッシュボードの確認"
  echo "  □ リリースノート（D-RELNOTE）の最終確認"
  echo ""
fi

# 実際の実行はここから
run_checks() {
  local gate="$1"
  local started_ms
  started_ms=$(now_ms)
  local deliv_fail=0
  local static_pass=0
  local static_fail=0
  local static_skip=0
  local ai_pass=0
  local ai_fail=0
  local escaped_gate
  escaped_gate="${gate//./\\.}"
  local section_heading_re='^G[0-9]+([.][0-9]+)?[A-Z]?:'

  # deliverable check の前に state を自動更新
  if [[ -f "$HELIX_DIR/matrix.yaml" ]]; then
    local state_file="$HELIX_DIR/state/deliverables.json"
    cp "$state_file" "$state_file.prev" 2>/dev/null || true
    python3 "$SCRIPT_DIR/lib/matrix_compiler.py" --project-root "$PROJECT_ROOT" auto-detect 2>/dev/null || true
    HELIX_STATE_PREV="$state_file.prev" HELIX_STATE_CURR="$state_file" python3 - <<'PY' 2>/dev/null || true
import json
import os


def collect_statuses(payload):
    statuses = {}
    features = payload.get("features", {})
    if not isinstance(features, dict):
        return statuses
    for feature_id, feature in features.items():
        if not isinstance(feature, dict):
            continue
        deliverables = feature.get("deliverables", {})
        if not isinstance(deliverables, dict):
            continue
        for did, entry in deliverables.items():
            if not isinstance(entry, dict):
                continue
            statuses[f"{feature_id}/{did}"] = str(entry.get("status", "pending"))
    return statuses


prev_path = os.environ.get("HELIX_STATE_PREV", "")
curr_path = os.environ.get("HELIX_STATE_CURR", "")
if not prev_path or not curr_path:
    raise SystemExit(0)
if not os.path.exists(prev_path) or not os.path.exists(curr_path):
    raise SystemExit(0)

with open(prev_path, "r", encoding="utf-8") as fp:
    prev = json.load(fp)
with open(curr_path, "r", encoding="utf-8") as fp:
    curr = json.load(fp)

prev_status = collect_statuses(prev)
curr_status = collect_statuses(curr)
drifted = sorted(
    key for key, old_status in prev_status.items()
    if old_status == "done" and curr_status.get(key) == "pending"
)
if drifted:
    print("[helix-gate] WARN: auto-detect により done → pending へ戻った成果物があります")
    for item in drifted[:10]:
        print(f"[helix-gate]   - {item}")
    if len(drifted) > 10:
        print(f"[helix-gate]   ... +{len(drifted) - 10} 件")
PY
  fi

  # --- Deliverable Check ---
  local index_file="$HELIX_DIR/runtime/index.json"
  local state_file="$HELIX_DIR/state/deliverables.json"
  if [[ -f "$index_file" && -f "$state_file" ]]; then
    echo "[deliverable]"
    if python3 "$DELIVERABLE_GATE" --index "$index_file" --state "$state_file" --gate "$gate"; then
      echo ""
    else
      deliv_fail=1
      echo ""
    fi
  fi

  # G2/G4 ミニレトロの記入チェック
  if [[ "$gate" == "G6" ]]; then
    for retro in "$HELIX_DIR"/retros/*-G4.md; do
      [[ -f "$retro" ]] || continue
      if grep -qE '^-\s*$' "$retro" 2>/dev/null; then
        echo "  WARN: レトロ未記入: $(basename "$retro")"
        echo "    Keep/Problem/Try を記入してください"
      fi
    done
  fi

  # --- Fullstack Twin Track Check ---
  if [[ -f "$PHASE_FILE" ]]; then
    local drive
    drive=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.drive" 2>/dev/null || echo "")
    if [[ "$drive" == "fullstack" && ("$gate" == "G3" || "$gate" == "G4") ]]; then
      echo "[fullstack]"
      # G4: BE/FE 両 track の stage が .5 かつ status が completed であること
      if [[ "$gate" == "G4" ]]; then
        local be_stage fe_stage contract_ci be_status fe_status
        be_stage=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.be.stage" 2>/dev/null || echo "")
        fe_stage=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.fe.stage" 2>/dev/null || echo "")
        be_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.be.status" 2>/dev/null || echo "")
        fe_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.fe.status" 2>/dev/null || echo "")
        contract_ci=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.contract.ci" 2>/dev/null || echo "")

        local twin_fail=0
        if [[ "$be_stage" != ".5" || "$be_status" != "completed" ]]; then
          echo "  FAIL: BE Track 未完了 (stage=$be_stage, status=$be_status)"
          twin_fail=1
        fi
        if [[ "$fe_stage" != ".5" || "$fe_status" != "completed" ]]; then
          echo "  FAIL: FE Track 未完了 (stage=$fe_stage, status=$fe_status)"
          twin_fail=1
        fi
        if [[ "$contract_ci" != "pass" ]]; then
          echo "  FAIL: Contract CI 未通過 (ci=$contract_ci)"
          twin_fail=1
        fi
        if [[ $twin_fail -gt 0 ]]; then
          deliv_fail=$((deliv_fail + twin_fail))
          echo "  fullstack G4: FAIL"
        else
          echo "  fullstack G4: BE .5 ✓ FE .5 ✓ Contract CI ✓"
        fi
        echo ""
      fi
    fi
  fi

  if [[ "$AI_ONLY" != true ]]; then
    echo "[static]"

    # gate-checks.yaml からこのゲートの static チェックを抽出・実行
    local in_gate=false
    local in_static=false
    local check_name=""
    local check_cmd=""

    while IFS= read -r line; do
      if [[ "$line" =~ ^${escaped_gate}:[[:space:]]*$ ]]; then
        in_gate=true
        continue
      fi
      # 次のゲート定義に入ったら終了
      if [[ "$in_gate" == true && "$line" =~ $section_heading_re ]]; then
        break
      fi
      if [[ "$in_gate" == true && "$line" =~ ^[[:space:]]+static: ]]; then
        in_static=true
        continue
      fi
      if [[ "$in_gate" == true && "$in_static" == true ]]; then
        # ai: セクションに入ったら static 終了
        if [[ "$line" =~ ^[[:space:]]+ai: ]]; then
          # 残りのチェックを実行
          if [[ -n "$check_cmd" ]]; then
            if [[ "$DRY_RUN" == true ]]; then
              echo "  [dry-run] $check_name: $check_cmd"
            else
              if (cd "$PROJECT_ROOT" && bash -c "$check_cmd") >/dev/null 2>&1; then
                echo "  PASS: $check_name"
                static_pass=$((static_pass + 1))
              else
                echo "  FAIL: $check_name"
                echo "    cmd: $check_cmd"
                static_fail=$((static_fail + 1))
              fi
            fi
          fi
          in_static=false
          continue
        fi
        if [[ "$line" =~ name:[[:space:]]*\"(.+)\" ]]; then
          # 前のチェックを実行
          if [[ -n "$check_cmd" ]]; then
            if [[ "$DRY_RUN" == true ]]; then
              echo "  [dry-run] $check_name: $check_cmd"
            else
              if (cd "$PROJECT_ROOT" && bash -c "$check_cmd") >/dev/null 2>&1; then
                echo "  PASS: $check_name"
                static_pass=$((static_pass + 1))
              else
                echo "  FAIL: $check_name"
                echo "    cmd: $check_cmd"
                static_fail=$((static_fail + 1))
              fi
            fi
          fi
          check_name="${BASH_REMATCH[1]}"
          check_cmd=""
        elif [[ "$line" =~ cmd:[[:space:]]*\"(.+)\" ]]; then
          check_cmd="${BASH_REMATCH[1]}"
        fi
      fi
    done < "$GATE_CHECKS"

    # 最後のチェック
    if [[ "$in_static" == true && -n "$check_cmd" ]]; then
      if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] $check_name: $check_cmd"
      else
        if (cd "$PROJECT_ROOT" && bash -c "$check_cmd") >/dev/null 2>&1; then
          echo "  PASS: $check_name"
          static_pass=$((static_pass + 1))
        else
          echo "  FAIL: $check_name"
          echo "    cmd: $check_cmd"
          static_fail=$((static_fail + 1))
        fi
      fi
    fi

    if [[ $((static_pass + static_fail)) -eq 0 ]]; then
      echo "  (static チェックなし)"
    else
      echo ""
      echo "  static: $static_pass pass, $static_fail fail"
    fi
    echo ""
  fi

  # --- AI チェック ---
  if [[ "$STATIC_ONLY" != true ]]; then
    echo "[helix-gate] TL レビュー（Codex 5.4）"
    echo "[ai]"

    local in_gate=false
    local in_ai=false
    local ai_role=""
    local ai_task=""
    local ai_count=0

    run_ai_check() {
      local role="$1"
      local task="$2"

      ai_count=$((ai_count + 1))
      if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] helix-codex --role $role --task \"${task:0:60}...\""
        return
      fi

      echo "  実行中: helix-codex --role $role ..."
      local ai_output_file
      ai_output_file=$(mktemp "${TMPDIR:-/tmp}/helix-gate-ai-XXXXXX")

      set +e
      "$HELIX_CODEX" --role "$role" --task "$task" >"$ai_output_file" 2>&1
      local ai_exit=$?
      set -e

      cat "$ai_output_file"

      local verdict=""
      verdict=$(grep -Eo '"verdict"[[:space:]]*:[[:space:]]*"(approve|needs-attention)"' "$ai_output_file" | head -n1 | sed -E 's/.*"(approve|needs-attention)"/\1/' || true)

      if [[ "$verdict" == "needs-attention" ]]; then
        ai_fail=$((ai_fail + 1))
        echo "  [ai] FAIL: $role (verdict: needs-attention)"
      elif [[ -n "$verdict" ]]; then
        ai_pass=$((ai_pass + 1))
      elif [[ "$ai_exit" -eq 0 ]]; then
        ai_pass=$((ai_pass + 1))
      else
        ai_fail=$((ai_fail + 1))
        echo "  [ai] FAIL: $role"
      fi

      rm -f "$ai_output_file"
      echo ""
    }

    while IFS= read -r line; do
      if [[ "$line" =~ ^${escaped_gate}:[[:space:]]*$ ]]; then
        in_gate=true
        continue
      fi
      if [[ "$in_gate" == true && "$line" =~ $section_heading_re ]]; then
        break
      fi
      if [[ "$in_gate" == true && "$line" =~ ^[[:space:]]+ai: ]]; then
        in_ai=true
        continue
      fi
      if [[ "$in_ai" == true ]]; then
        if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*role:[[:space:]]*(.+) ]]; then
          # 前の AI チェックを実行
          if [[ -n "$ai_role" && -n "$ai_task" ]]; then
            run_ai_check "$ai_role" "$ai_task"
          fi
          ai_role="${BASH_REMATCH[1]}"
          ai_task=""
        elif [[ "$line" =~ task:[[:space:]]*\|[[:space:]]*$ ]]; then
          # multiline task 開始
          ai_task=""
        elif [[ "$in_ai" == true && -n "$ai_role" && "$line" =~ ^[[:space:]]{8} ]]; then
          # multiline task の続き
          ai_task+="${line#        }"$'\n'
        fi
      fi
    done < "$GATE_CHECKS"

    # 最後の AI チェック
    if [[ -n "$ai_role" && -n "$ai_task" ]]; then
      run_ai_check "$ai_role" "$ai_task"
    fi

    if [[ $ai_count -eq 0 ]]; then
      echo "  (AI チェックなし)"
    else
      echo "  ai: $ai_pass pass, $ai_fail fail"
    fi
  fi

  # --- 総合判定 ---
  local total_fail=$((deliv_fail + static_fail + ai_fail))
  local ended_ms duration_ms result
  ended_ms=$(now_ms)
  duration_ms=$((ended_ms - started_ms))
  if [[ $total_fail -gt 0 ]]; then
    result="fail"
  else
    result="pass"
  fi
  if [[ "$DRY_RUN" != true ]]; then
    log_gate_run "$gate" "$result" "$deliv_fail" "$static_fail" "$ai_fail" "$duration_ms"
  fi
  echo ""
  if [[ $total_fail -gt 0 ]]; then
    echo "=== $gate FAIL (deliverable: $deliv_fail fail, static: $static_fail fail, ai: $ai_fail fail) ==="
    if [[ "$DRY_RUN" != true && -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.status" "failed" 2>/dev/null || true
    fi
    exit 1
  else
    echo "=== $gate PASS ==="
    if [[ "$DRY_RUN" != true && -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.status" "passed" 2>/dev/null || true
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.date" "$(date '+%Y-%m-%d')" 2>/dev/null || true
      maybe_generate_retro "$gate"
    fi
    case "$gate" in
      G4)
        echo ""
        echo "[helix-gate] 品質改善の提案:"

        # TODO/FIXME/HACK/WORKAROUND の残存数を集計
        todo_count=$( (rg -c 'TODO|FIXME|HACK|WORKAROUND' src/ 2>/dev/null || true) | awk -F: '{s+=$2}END{print s+0}' )
        if [[ $todo_count -gt 0 ]]; then
          echo "  TODO/FIXME: $todo_count 件 → helix debt add で台帳化を推奨"
        fi

        # 負債台帳の未解決件数サマリ
        if [[ -f "$HELIX_DIR/debt-register.yaml" ]]; then
          debt_count=$(grep -c "status: open" "$HELIX_DIR/debt-register.yaml" 2>/dev/null || true)
          debt_count="${debt_count:-0}"
          echo "  技術負債: $debt_count 件（未解決）→ 次イテレーション 20% 枠で対応推奨"
        fi

        echo "  helix promote --auto で昇格候補を確認"
        echo "  helix bench で品質推移を確認"
        echo "次のアクション: helix gate G5 または helix gate G6 に進んでください"
        echo "[helix-gate] ヒント: 'helix promote --auto' で昇格候補を確認できます"
        ;;
      G6)
        echo "[helix-gate] ヒント: E2E テストを実行してください"
        echo "  npx playwright test（Playwright）"
        echo "  npm test -- --coverage（Jest）"
        echo "  pytest --cov（pytest）"
        echo "次のアクション: helix gate G7 → helix pr でリリース準備"
        ;;
      G7)
        echo "次のアクション: helix pr で PR を作成してください"
        echo ""
        echo "[helix-gate] L8 受入準備:"
        echo "  受入条件（D-ACC）と実装の突合を実施してください"
        echo "  helix matrix status で全成果物の状態を確認"
        ;;
    esac
  fi
}

# --- ミニレトロ自動生成 ---
maybe_generate_retro() {
  local gate="$1"
  local phase_desc=""

  case "$gate" in
    G2) phase_desc="設計フェーズ (L1-L2)" ;;
    G4) phase_desc="実装フェーズ (L3-L4)" ;;
    *)  return ;;
  esac

  local retro_dir="$HELIX_DIR/retros"
  mkdir -p "$retro_dir"
  local today
  today=$(date '+%Y-%m-%d')
  local retro_file="$retro_dir/${today}-${gate}.md"

  if [[ -f "$retro_file" ]]; then
    echo ""
    echo "[helix-gate] Retro already exists: $retro_file"
    return
  fi

  local template="$SCRIPT_DIR/templates/retro.md.template"
  if [[ -f "$template" ]]; then
    sed -e "s/{{GATE}}/$gate/g" \
        -e "s/{{DATE}}/$today/g" \
        -e "s/{{PHASE_DESC}}/$phase_desc/g" \
        "$template" > "$retro_file"
  else
    cat > "$retro_file" <<RETRO
# Mini Retro: $gate ($today)

## Phase: $phase_desc

### Keep（うまくいったこと）
-

### Problem（問題があったこと）
-

### Try（次に試すこと）
| アクション | 担当 | 期日 |
|-----------|------|------|
| | | |
RETRO
  fi

  echo ""
  echo "[helix-gate] ミニレトロ生成: $retro_file"
  echo "[helix-gate]   内容を記入してください（Try は owner + due 必須）"
}

run_checks "$GATE"
