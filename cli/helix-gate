        echo "  helix matrix status で全成果物の状態を確認"
        ;;
    esac
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$gate" "pass" "$static_pass" "$static_fail" "$prereq"
    fi
  fi
}

# --- ミニレトロ自動生成 ---
maybe_generate_retro() {
  local gate="$1"
  local phase_desc=""

  case "$gate" in
    G2) phase_desc="設計フェーズ (L1-L2)" ;;
    G4) phase_desc="実装フェーズ (L3-L4)" ;;
    *)  return ;;
  esac

  local retro_dir="$HELIX_DIR/retros"
  mkdir -p "$retro_dir"
  local today
  today=$(date '+%Y-%m-%d')
  local retro_file="$retro_dir/${today}-${gate}.md"

  if [[ -f "$retro_file" ]]; then
    echo ""
    echo "[helix-gate] Retro already exists: $retro_file"
    return
  fi

  local template="$SCRIPT_DIR/templates/retro.md.template"
  if [[ -f "$template" ]]; then
    sed -e "s/{{GATE}}/$gate/g" \
        -e "s/{{DATE}}/$today/g" \
        -e "s/{{PHASE_DESC}}/$phase_desc/g" \
        "$template" > "$retro_file"
  else
    cat > "$retro_file" <<RETRO
# Mini Retro: $gate ($today)

## Phase: $phase_desc

## Keep
- うまくいったことを記載

## Problem
- 問題だったことを記載

## Try
- @owner 2026-01-01 次に試すアクション
RETRO
  fi

  echo ""
  echo "[helix-gate] ミニレトロ生成: $retro_file"
  echo "[helix-gate]   内容を記入してください（Try の @owner と YYYY-MM-DD は推奨）"
}

run_checks "$GATE"
