#!/bin/bash
if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "エラー: helix-gate は bash 4 以上が必要です (現 ${BASH_VERSION:-unknown})" >&2
  echo "macOS の場合: brew install bash && シェルを /opt/homebrew/bin/bash に変更" >&2
  exit 1
fi
set -euo pipefail

# helix-gate: HELIX ゲート自動検証
# Usage: helix-gate <gate-name> [--static-only] [--ai-only] [--dry-run]
#
# 責務分離:
#   1. 前提条件チェック（prereq gate）      → check_prerequisites()
#   2. Deliverable チェック                 → deliverable_gate.py
#   3. Static チェック                      → gate-checks.yaml 実行
#   4. AI チェック                          → helix-codex 委譲
#   5. 総合判定 + phase.yaml 更新           → update_phase()
#   6. 後処理（retro 生成、提案メッセージ）  → post_gate()

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
GATE_CHECKS="$HELIX_DIR/gate-checks.yaml"
PHASE_FILE="$HELIX_DIR/phase.yaml"
HELIX_CODEX="$SCRIPT_DIR/helix-codex"
REVIEW_SCHEMA="$SCRIPT_DIR/schemas/review-output.schema.json"

# --- 引数パース ---
GATE=""
STATIC_ONLY=false
AI_ONLY=false
DRY_RUN=false
UNDO=false
JSON_OUTPUT=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --static-only) STATIC_ONLY=true; shift ;;
    --ai-only)     AI_ONLY=true; shift ;;
    --dry-run)     DRY_RUN=true; shift ;;
    --undo)        UNDO=true; shift ;;
    --json)        JSON_OUTPUT=true; shift ;;
    --help|-h)
      echo "使い方: helix gate <gate> [--static-only] [--ai-only] [--dry-run] [--undo] [--json]"
      echo ""
      echo "Gates: G0.5, G2, G3, G4, G5, G6, G7"
      exit "$EXIT_SUCCESS"
      ;;
    *)
      if [[ -z "$GATE" ]]; then
        GATE="$1"; shift
      else
        echo "エラー: 不明なオプションです: $1" >&2; exit "$EXIT_INPUT_ERROR"
      fi
      ;;
  esac
done

if [[ "$JSON_OUTPUT" == true ]]; then
  exec 3>&1
  exec 1>&2
fi

if [[ -z "$GATE" ]]; then
  echo "エラー: ゲート名が必要です（G0.5, G1, G1R, G1.5, G2, G3, G4, G5, G6, G7）" >&2
  exit "$EXIT_INPUT_ERROR"
fi

if [[ ! "$GATE" =~ ^G(0\.5|1|1R|1\.5|[2-7])$ ]]; then
  echo "エラー: 無効なゲートです: $GATE（G0.5, G1, G1R, G1.5, G2-G7 を指定してください）" >&2
  exit "$EXIT_INPUT_ERROR"
fi

emit_gate_json() {
  local gate="$1"
  local result="$2"
  local static_pass="$3"
  local static_fail="$4"
  local prereq_gate="$5"
  GATE_JSON_GATE="$gate" \
  GATE_JSON_RESULT="$result" \
  GATE_JSON_STATIC_PASS="$static_pass" \
  GATE_JSON_STATIC_FAIL="$static_fail" \
  GATE_JSON_PREREQ="$prereq_gate" \
  python3 - <<'PY' >&3
import json
import os

print(
    json.dumps(
        {
            "gate": os.environ.get("GATE_JSON_GATE", ""),
            "result": os.environ.get("GATE_JSON_RESULT", ""),
            "checks": {
                "static_pass": int(os.environ.get("GATE_JSON_STATIC_PASS", "0")),
                "static_fail": int(os.environ.get("GATE_JSON_STATIC_FAIL", "0")),
            },
            "prereq": os.environ.get("GATE_JSON_PREREQ", ""),
        },
        ensure_ascii=False,
    )
)
PY
}

YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
DELIVERABLE_GATE="$SCRIPT_DIR/lib/deliverable_gate.py"
DESIGN_MD_WRAPPER="$SCRIPT_DIR/libexec/design-md"

STATE_MACHINE="$SCRIPT_DIR/templates/state-machine.yaml"
if [[ ! -f "$STATE_MACHINE" ]]; then
  echo "エラー: state-machine.yaml が見つかりません" >&2
  exit $EXIT_INTERNAL_ERROR
fi

write_phase_or_die() {
  local dotpath="$1"
  local value="$2"
  if ! python3 "$YAML_PARSER" write "$PHASE_FILE" "$dotpath" "$value"; then
    echo "エラー: phase.yaml 更新失敗: ${dotpath}=${value}" >&2
    exit "$EXIT_INTERNAL_ERROR"
  fi
}

declare -A GATE_PREREQS
while IFS=: read -r gate prereq; do
  GATE_PREREQS["$gate"]="$prereq"
done < <(python3 "$YAML_PARSER" dump "$STATE_MACHINE" 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
for g, v in d.get('gates', {}).items():
    p = v.get('prereqs', [])
    print(f'{g}:{p[0] if p else \"\"}')
")

if [[ -f "$CONFIG_FILE" ]]; then
  skip_gates=$(python3 "$YAML_PARSER" read "$CONFIG_FILE" gate_skip 2>/dev/null || echo '[]')
  if echo "$skip_gates" | grep -q "$GATE"; then
    echo "=== $GATE: config.yaml で skip 設定済み ==="
    if [[ -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.status" skipped 2>/dev/null || true
    fi
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$GATE" "skipped" 0 0 "${GATE_PREREQS[$GATE]:-}"
    fi
    exit 0
  fi
fi

# G5 自動 skip 判定: drive=be|db かつ UI フラグなしなら auto-skipped
if [[ "$GATE" == "G5" && -f "$PHASE_FILE" ]]; then
  auto_drive=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.drive" 2>/dev/null || echo "")
  ui_flag=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.ui" 2>/dev/null || echo "")
  if [[ ("$auto_drive" == "be" || "$auto_drive" == "db") && "$ui_flag" != "true" ]]; then
    echo "=== G5: drive=$auto_drive + ui=false, skip (L5/G5 不要、auto-skipped) ==="
    python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.G5.status" skipped 2>/dev/null || true
    python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.G5.note" "auto-skipped: drive=${auto_drive}, no UI" 2>/dev/null || true
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "G5" "skipped" 0 0 "${GATE_PREREQS[G5]:-}"
    fi
    exit 0
  fi
fi

if [[ "$UNDO" == true ]]; then
  if [[ ! -f "$PHASE_FILE" ]]; then
    echo "エラー: $PHASE_FILE が見つかりません。'helix-init' を実行してください。" >&2
    exit "$EXIT_PREREQ_ERROR"
  fi
  python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.status" "pending" 2>/dev/null || true
  python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.date" "" 2>/dev/null || true
  cascade=$(python3 "$YAML_PARSER" dump "$STATE_MACHINE" 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
inv = d.get('gates',{}).get('$GATE',{}).get('on_invalidate',[])
print(' '.join(inv))
")
  for cg in $cascade; do
    python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${cg}.status" invalidated 2>/dev/null || true
  done
  if [[ -n "$cascade" ]]; then
    echo "下流ゲート ($cascade) を invalidated にしました"
  fi
  echo "=== $GATE を pending に戻しました ==="
  exit "$EXIT_SUCCESS"
fi

if [[ ! -f "$GATE_CHECKS" ]]; then
  echo "エラー: $GATE_CHECKS が見つかりません。'helix-init' を実行してください。" >&2
  exit "$EXIT_PREREQ_ERROR"
fi

now_ms() {
  local ms
  ms=$(date +%s%3N 2>/dev/null || true)
  if [[ -z "$ms" ]]; then
    ms=$(( $(date +%s) * 1000 ))
  fi
  echo "$ms"
}

log_gate_run() {
  local gate="$1"
  local result="$2"
  local deliv_fail="$3"
  local static_fail="$4"
  local ai_fail="$5"
  local duration_ms="$6"
  local extra_fail_reasons="${7:-}"
  local payload
  local fail_reasons="deliverable:$deliv_fail,static:$static_fail,ai:$ai_fail"
  if [[ -n "$extra_fail_reasons" ]]; then
    fail_reasons="${fail_reasons},${extra_fail_reasons}"
  fi
  payload="{\"gate\":\"$gate\",\"result\":\"$result\",\"fail_reasons\":\"$fail_reasons\",\"duration_ms\":$duration_ms}"
  HELIX_DB_PATH="$HELIX_DIR/helix.db" python3 "$SCRIPT_DIR/lib/helix_db.py" insert gate_runs "$payload" 2>/dev/null || true
}

log_gate_summary() {
  local gate="$1" result="$2" deliv_fail="$3" static_fail="$4" ai_fail="$5"
  local summary_dir="$HELIX_DIR/session-summaries"
  mkdir -p "$summary_dir" 2>/dev/null || true
  local today now summary_file
  today=$(date '+%Y-%m-%d')
  now=$(date '+%Y-%m-%d %H:%M')
  summary_file="$summary_dir/${today}-session.md"
  {
    echo ""
    echo "## ゲート通過: $gate ($now)"
    echo ""
    echo "- 結果: $result"
    echo "- deliverable fail: $deliv_fail, static fail: $static_fail, ai fail: $ai_fail"
  } >> "$summary_file"
}

_emit_feedback() {
  local gate="$1"
  local gate_display_name="$2"
  local summary="$3"

  [[ "$gate" =~ ^G[2-7]$ ]] || return 0
  [[ "${HELIX_DISABLE_FEEDBACK:-}" == "1" ]] && return 0
  [[ "$DRY_RUN" == true ]] && return 0

  python3 "$SCRIPT_DIR/lib/feedback_hook.py" \
    --project-root "$PROJECT_ROOT" \
    --helix-dir "$HELIX_DIR" \
    --gate "$gate" \
    --gate-name "$gate_display_name" \
    --summary "$summary" || true
}

record_ai_review_scores() {
  local role="$1"
  local output_file="$2"
  local gate="$3"
  local task="$4"

  python3 - <<'PY' "$SCRIPT_DIR/lib" "$HELIX_DIR/helix.db" "$PHASE_FILE" "$REVIEW_SCHEMA" "$role" "$output_file" "$gate" "$task" || true
import sys
import os
from pathlib import Path

lib_dir = Path(sys.argv[1])
db_path = Path(sys.argv[2])
phase_file = Path(sys.argv[3])
schema_file = Path(sys.argv[4])
role = sys.argv[5]
output_file = Path(sys.argv[6])
gate = sys.argv[7]
task = sys.argv[8]
sys.path.insert(0, str(lib_dir))

import helix_db
import review_output
import yaml_parser


def resolve_plan_id() -> str:
    env_plan_id = os.environ.get("HELIX_PLAN_ID", "").strip()
    if env_plan_id:
        return env_plan_id
    if phase_file.exists():
        data = yaml_parser.parse_yaml(phase_file.read_text(encoding="utf-8"))
        value = data.get("plan_id")
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


text = output_file.read_text(encoding="utf-8", errors="replace")
try:
    payload = review_output.extract_normalized_review_json(text, review_output.load_schema(schema_file))
except review_output.ReviewOutputError:
    raise SystemExit(0)

plan_id = resolve_plan_id()
if not plan_id:
    raise SystemExit(0)

task_preview = task[:500]
evidence = f"source=helix-gate ai review\nrole={role}\ntask_preview={task_preview}"
reviewer = f"codex-review:{role}"
conn = helix_db._connect(str(db_path))
try:
    helix_db._ensure_schema(conn)
    conn.execute(
        "DELETE FROM accuracy_score WHERE plan_id = ? AND gate = ? AND reviewer = ?",
        (plan_id, gate, reviewer),
    )
    conn.commit()
finally:
    conn.close()

for score in payload.get("overall_scores", []):
    helix_db.record_accuracy_score(
        str(db_path),
        plan_id=plan_id,
        gate=gate,
        dimension=score["dimension"],
        level=score["level"],
        comment=score.get("comment", ""),
        evidence=evidence,
        reviewer=reviewer,
    )
PY
}

prereq="${GATE_PREREQS[$GATE]:-}"
if [[ -n "$prereq" && -f "$PHASE_FILE" && -f "$YAML_PARSER" ]]; then
  prereq_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "gates.${prereq}.status" 2>/dev/null || echo "pending")
  if [[ "$prereq_status" != "passed" && "$prereq_status" != "skipped" ]]; then
    echo "エラー: 前提ゲート $prereq が未通過です (status: $prereq_status)" >&2
    echo "$prereq を先に通過させてください" >&2
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$GATE" "fail" 0 0 "$prereq"
    fi
    exit "$EXIT_PREREQ_ERROR"
  fi
fi

# --- ゲート名を取得 ---
gate_name=$(
  python3 - "$GATE_CHECKS" "$GATE" <<'PY'
import re, sys

gate_checks = sys.argv[1]
gate = sys.argv[2]

with open(gate_checks, "r", encoding="utf-8") as fp:
    lines = fp.readlines()

in_gate = False
gate_header = re.compile(rf"^\s*{re.escape(gate)}:\s*$")
next_gate_header = re.compile(r"^G[0-9]+([.][0-9]+)?[A-Z]?:\s*$")

for line in lines:
    stripped = line.strip()
    if not in_gate:
        if gate_header.match(line):
            in_gate = True
        continue
    if next_gate_header.match(stripped):
        break
    m = re.match(r'\s*name:\s*"([^"]+)"', line)
    if m:
        print(m.group(1))
        break
PY
)
gate_name="${gate_name:-$GATE}"

echo ""
echo "=== $GATE: $gate_name ==="
echo ""

if [[ "$GATE" == "G7" ]]; then
  echo "[helix-gate] デプロイ前チェックリスト:"
  echo "  □ staging 環境でのスモークテスト完了"
  echo "  □ ロールバック手順の確認"
  echo "  □ DB マイグレーションの rehearsal 完了"
  echo "  □ 監視ダッシュボードの確認"
  echo "  □ リリースノート（D-RELNOTE）の最終確認"
  echo ""
fi

# 実際の実行はここから
run_checks() {
  local gate="$1"
  local started_ms
  started_ms=$(now_ms)
  local deliv_fail=0
  local static_pass=0
  local static_fail=0
  local static_skip=0
  local mandatory_pass=0
  local mandatory_fail=0
  local advisory_pass=0
  local advisory_fail=0
  local ai_pass=0
  local ai_fail=0
  local drive=""
  local ui_flag=""
  local extra_fail_reasons=""
  if [[ -f "$PHASE_FILE" ]]; then
    drive=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.drive" 2>/dev/null || echo "")
    ui_flag=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.ui" 2>/dev/null || echo "")
  fi

  is_fe_driven_gate() {
    [[ "$drive" == "fe" || "$drive" == "fullstack" ]]
  }

  add_fail_reason() {
    local reason="$1"
    [[ -n "$reason" ]] || return 0
    if [[ ",$extra_fail_reasons," == *",$reason,"* ]]; then
      return 0
    fi
    if [[ -n "$extra_fail_reasons" ]]; then
      extra_fail_reasons="${extra_fail_reasons},${reason}"
    else
      extra_fail_reasons="$reason"
    fi
  }

  requires_design_md_lint() {
    local drive_value="$1"
    local ui_value="$2"
    case "$drive_value" in
      fe|fullstack)
        return 0
        ;;
      agent|be|db)
        [[ "$ui_value" == "true" ]]
        return $?
        ;;
      *)
        return 1
        ;;
    esac
  }

  debt_status_by_id() {
    local debt_id="$1"
    local register="$HELIX_DIR/debt-register.yaml"
    python3 - "$register" "$debt_id" <<'PY'
import re
import sys

register = sys.argv[1]
target = sys.argv[2]

try:
    with open(register, "r", encoding="utf-8") as fp:
        lines = fp.readlines()
except FileNotFoundError:
    print("missing")
    raise SystemExit(0)

item_re = re.compile(r"^\s*-\s+id:\s*(.+?)\s*$")
status_re = re.compile(r"^\s*status:\s*(.+?)\s*$")

active = False
for raw in lines:
    m_item = item_re.match(raw)
    if m_item:
        value = m_item.group(1).strip().strip('"').strip("'")
        active = value == target
        continue
    if active:
        m_status = status_re.match(raw)
        if m_status:
            print(m_status.group(1).strip().strip('"').strip("'"))
            raise SystemExit(0)

print("missing")
PY
  }

  enqueue_mock_driven_debts() {
    "$SCRIPT_DIR/helix-debt" add \
      --id MOCK-DERIVED-CONTRACT --title 'モック由来 API 契約のドメイン整合性を L6 で TL レビュー' \
      --priority high --category mock-driven --impact high --effort M \
      --owner TL --target-sprint L6 --source 'helix-gate G2 auto-enqueue'

    "$SCRIPT_DIR/helix-debt" add \
      --id MOCK-HARDCODE --title 'モックのハードコード値残存を G4 で grep チェック' \
      --priority medium --category mock-driven --impact medium --effort S \
      --owner SE --target-sprint G4 --source 'helix-gate G2 auto-enqueue'

    "$SCRIPT_DIR/helix-debt" add \
      --id MOCK-CODE-LEAK --title '.helix/mock/ 配下の本実装への import 禁止を G4 で AST チェック' \
      --priority high --category mock-driven --impact high --effort S \
      --owner SE --target-sprint G4 --source 'helix-gate G2 auto-enqueue'
  }

  check_retro_sections() {
    local retro_file="$1"
    python3 - "$retro_file" <<'PY'
import re
import sys
from pathlib import Path

retro_file = Path(sys.argv[1])
text = retro_file.read_text(encoding="utf-8")
required_sections = ("Keep", "Problem", "Try")
missing = []
warnings = []

for section in required_sections:
    pattern = rf"^## {section}\s*$"
    m = re.search(pattern, text, flags=re.MULTILINE)
    if not m:
        missing.append(f"section_missing:{section}")
        continue
    start = m.end()
    next_m = re.search(r"^##\s+", text[start:], flags=re.MULTILINE)
    end = start + next_m.start() if next_m else len(text)
    block = text[start:end]
    bullets = re.findall(r"^- .+$", block, flags=re.MULTILINE)
    if len(bullets) == 0:
        missing.append(f"bullet_missing:{section}")

    if section == "Try" and bullets:
        has_owner = any(re.search(r"@\w+", line) for line in bullets)
        has_due = any(re.search(r"\b\d{4}-\d{2}-\d{2}\b", line) for line in bullets)
        if not has_owner or not has_due:
            warnings.append("Try section は @owner と YYYY-MM-DD の記載を推奨")

if missing:
    print(f"FAIL: {retro_file.name} -> {', '.join(missing)}")
    raise SystemExit(1)

print(f"PASS: {retro_file.name}")
for warning in warnings:
    print(f"WARN: {retro_file.name} -> {warning}")
PY
  }

  check_adversarial_requirement_runtime() {
    local risk_defs_file=""
    if [[ -f "$HELIX_DIR/rules/common-defs.yaml" ]]; then
      risk_defs_file="$HELIX_DIR/rules/common-defs.yaml"
    elif [[ -f "$SCRIPT_DIR/templates/rules/common-defs.yaml" ]]; then
      risk_defs_file="$SCRIPT_DIR/templates/rules/common-defs.yaml"
    fi

    local matrix_file="$HELIX_DIR/matrix.yaml"
    local risk_eval="false	S		"
    if [[ -f "$matrix_file" ]]; then
      risk_eval=$(python3 - "$matrix_file" "$risk_defs_file" "$SCRIPT_DIR/lib" <<'PY'
import json
import sys
from pathlib import Path

matrix_path = Path(sys.argv[1])
risk_defs_path = Path(sys.argv[2]) if sys.argv[2] else None
lib_path = Path(sys.argv[3])
sys.path.insert(0, str(lib_path))
import yaml_parser

matrix = yaml_parser.parse_yaml(matrix_path.read_text(encoding="utf-8"))
size = str((matrix.get("project") or {}).get("size") or "S")
features = matrix.get("features", {})
if not isinstance(features, dict):
    features = {}

canonical = {"auth", "payment", "pii", "external_api", "data_migration", "infra"}
if risk_defs_path and risk_defs_path.exists():
    defs = yaml_parser.parse_yaml(risk_defs_path.read_text(encoding="utf-8"))
    rf = defs.get("risk_flags", {})
    if isinstance(rf, dict) and rf:
        canonical = {k for k in rf.keys() if isinstance(k, str) and k}

flags = set()
themes = []
for feature_id, feature in features.items():
    if not isinstance(feature, dict):
        continue
    risk_flags = feature.get("risk_flags", [])
    if isinstance(risk_flags, str):
        risk_flags = [risk_flags]
    if not isinstance(risk_flags, list):
        continue
    selected = [f for f in risk_flags if isinstance(f, str) and f in canonical]
    if selected:
        themes.append(str(feature_id))
        flags.update(selected)

required = bool(flags) and size != "S"
print(
    f"{'true' if required else 'false'}\t{size}\t{','.join(sorted(flags))}\t{','.join(themes)}"
)
PY
)
    fi

    local needs_review project_size risky_flags risky_themes
    IFS=$'\t' read -r needs_review project_size risky_flags risky_themes <<< "$risk_eval"
    if [[ "$needs_review" != "true" ]]; then
      return 0
    fi

    local mechanical_only=false
    if [[ "${HELIX_MECHANICAL_ONLY:-}" == "1" || -f "$HELIX_DIR/mechanical-only.flag" ]]; then
      mechanical_only=true
    fi
    if [[ "$mechanical_only" == true ]]; then
      echo "WARN: adversarial-review skip（機械適用のみ）"
      return 0
    fi

    local same_theme_recent=""
    if [[ -n "$risky_themes" ]]; then
      same_theme_recent=$(python3 - "$HELIX_DIR/adversarial-review" "$risky_themes" <<'PY'
import re
import sys
import time
from pathlib import Path

review_dir = Path(sys.argv[1])
themes = [t for t in sys.argv[2].split(",") if t]
threshold = time.time() - (30 * 24 * 60 * 60)

if not review_dir.exists():
    raise SystemExit(0)

for theme in themes:
    review_file = review_dir / f"{theme}-G2.md"
    if not review_file.exists():
        continue
    if review_file.stat().st_mtime < threshold:
        continue
    text = review_file.read_text(encoding="utf-8")
    if re.search(r"^Reviewer:\s*\S+", text, flags=re.MULTILINE):
        print(theme)
        raise SystemExit(0)
PY
)
    fi
    if [[ -n "$same_theme_recent" ]]; then
      echo "WARN: adversarial-review skip（同一テーマ ${same_theme_recent} は30日以内に実施済み）"
      return 0
    fi

    local review_files=()
    if [[ -d "$HELIX_DIR/adversarial-review" ]]; then
      mapfile -t review_files < <(find "$HELIX_DIR/adversarial-review" -maxdepth 1 -type f -name '*-G2.md' | sort)
