#!/bin/bash
set -euo pipefail

# helix-gate: HELIX ゲート自動検証
# Usage: helix-gate <gate-name> [--static-only] [--ai-only] [--dry-run]
#
# 責務分離:
#   1. 前提条件チェック（prereq gate）      → check_prerequisites()
#   2. Deliverable チェック                 → deliverable_gate.py
#   3. Static チェック                      → gate-checks.yaml 実行
#   4. AI チェック                          → helix-codex 委譲
#   5. 総合判定 + phase.yaml 更新           → update_phase()
#   6. 後処理（retro 生成、提案メッセージ）  → post_gate()

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
GATE_CHECKS="$HELIX_DIR/gate-checks.yaml"
PHASE_FILE="$HELIX_DIR/phase.yaml"
HELIX_CODEX="$SCRIPT_DIR/helix-codex"

# --- 引数パース ---
GATE=""
STATIC_ONLY=false
AI_ONLY=false
DRY_RUN=false
UNDO=false
JSON_OUTPUT=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --static-only) STATIC_ONLY=true; shift ;;
    --ai-only)     AI_ONLY=true; shift ;;
    --dry-run)     DRY_RUN=true; shift ;;
    --undo)        UNDO=true; shift ;;
    --json)        JSON_OUTPUT=true; shift ;;
    --help|-h)
      echo "使い方: helix gate <gate> [--static-only] [--ai-only] [--dry-run] [--undo] [--json]"
      echo ""
      echo "Gates: G0.5, G2, G3, G4, G5, G6, G7"
      exit "$EXIT_SUCCESS"
      ;;
    *)
      if [[ -z "$GATE" ]]; then
        GATE="$1"; shift
      else
        echo "エラー: 不明なオプションです: $1" >&2; exit "$EXIT_INPUT_ERROR"
      fi
      ;;
  esac
done

if [[ "$JSON_OUTPUT" == true ]]; then
  exec 3>&1
  exec 1>&2
fi

if [[ -z "$GATE" ]]; then
  echo "エラー: ゲート名が必要です（G0.5, G1, G1R, G1.5, G2, G3, G4, G5, G6, G7）" >&2
  exit "$EXIT_INPUT_ERROR"
fi

if [[ ! "$GATE" =~ ^G(0\.5|1|1R|1\.5|[2-7])$ ]]; then
  echo "エラー: 無効なゲートです: $GATE（G0.5, G1, G1R, G1.5, G2-G7 を指定してください）" >&2
  exit "$EXIT_INPUT_ERROR"
fi

emit_gate_json() {
  local gate="$1"
  local result="$2"
  local static_pass="$3"
  local static_fail="$4"
  local prereq_gate="$5"
  GATE_JSON_GATE="$gate" \
  GATE_JSON_RESULT="$result" \
  GATE_JSON_STATIC_PASS="$static_pass" \
  GATE_JSON_STATIC_FAIL="$static_fail" \
  GATE_JSON_PREREQ="$prereq_gate" \
  python3 - <<'PY' >&3
import json
import os

print(
    json.dumps(
        {
            "gate": os.environ.get("GATE_JSON_GATE", ""),
            "result": os.environ.get("GATE_JSON_RESULT", ""),
            "checks": {
                "static_pass": int(os.environ.get("GATE_JSON_STATIC_PASS", "0")),
                "static_fail": int(os.environ.get("GATE_JSON_STATIC_FAIL", "0")),
            },
            "prereq": os.environ.get("GATE_JSON_PREREQ", ""),
        },
        ensure_ascii=False,
    )
)
PY
}

YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
DELIVERABLE_GATE="$SCRIPT_DIR/lib/deliverable_gate.py"

STATE_MACHINE="$SCRIPT_DIR/templates/state-machine.yaml"
if [[ ! -f "$STATE_MACHINE" ]]; then
  echo "エラー: state-machine.yaml が見つかりません" >&2
  exit $EXIT_INTERNAL_ERROR
fi
declare -A GATE_PREREQS
while IFS=: read -r gate prereq; do
  GATE_PREREQS["$gate"]="$prereq"
done < <(python3 "$YAML_PARSER" dump "$STATE_MACHINE" 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
for g, v in d.get('gates', {}).items():
    p = v.get('prereqs', [])
    print(f'{g}:{p[0] if p else \"\"}')
")

if [[ -f "$CONFIG_FILE" ]]; then
  skip_gates=$(python3 "$YAML_PARSER" read "$CONFIG_FILE" gate_skip 2>/dev/null || echo '[]')
  if echo "$skip_gates" | grep -q "$GATE"; then
    echo "=== $GATE: config.yaml で skip 設定済み ==="
    if [[ -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.status" skipped 2>/dev/null || true
    fi
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$GATE" "skipped" 0 0 "${GATE_PREREQS[$GATE]:-}"
    fi
    exit 0
  fi
fi

if [[ "$UNDO" == true ]]; then
  if [[ ! -f "$PHASE_FILE" ]]; then
    echo "エラー: $PHASE_FILE が見つかりません。'helix-init' を実行してください。" >&2
    exit "$EXIT_PREREQ_ERROR"
  fi
  python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.status" "pending" 2>/dev/null || true
  python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${GATE}.date" "" 2>/dev/null || true
  cascade=$(python3 "$YAML_PARSER" dump "$STATE_MACHINE" 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
inv = d.get('gates',{}).get('$GATE',{}).get('on_invalidate',[])
print(' '.join(inv))
")
  for cg in $cascade; do
    python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${cg}.status" invalidated 2>/dev/null || true
  done
  if [[ -n "$cascade" ]]; then
    echo "下流ゲート ($cascade) を invalidated にしました"
  fi
  echo "=== $GATE を pending に戻しました ==="
  exit "$EXIT_SUCCESS"
fi

if [[ ! -f "$GATE_CHECKS" ]]; then
  echo "エラー: $GATE_CHECKS が見つかりません。'helix-init' を実行してください。" >&2
  exit "$EXIT_PREREQ_ERROR"
fi

now_ms() {
  local ms
  ms=$(date +%s%3N 2>/dev/null || true)
  if [[ -z "$ms" ]]; then
    ms=$(( $(date +%s) * 1000 ))
  fi
  echo "$ms"
}

log_gate_run() {
  local gate="$1"
  local result="$2"
  local deliv_fail="$3"
  local static_fail="$4"
  local ai_fail="$5"
  local duration_ms="$6"
  local payload
  payload="{\"gate\":\"$gate\",\"result\":\"$result\",\"fail_reasons\":\"deliverable:$deliv_fail,static:$static_fail,ai:$ai_fail\",\"duration_ms\":$duration_ms}"
  HELIX_DB_PATH="$HELIX_DIR/helix.db" python3 "$SCRIPT_DIR/lib/helix_db.py" insert gate_runs "$payload" 2>/dev/null || true
}

log_gate_summary() {
  local gate="$1" result="$2" deliv_fail="$3" static_fail="$4" ai_fail="$5"
  local summary_dir="$HELIX_DIR/session-summaries"
  mkdir -p "$summary_dir" 2>/dev/null || true
  local today now summary_file
  today=$(date '+%Y-%m-%d')
  now=$(date '+%Y-%m-%d %H:%M')
  summary_file="$summary_dir/${today}-session.md"
  {
    echo ""
    echo "## ゲート通過: $gate ($now)"
    echo ""
    echo "- 結果: $result"
    echo "- deliverable fail: $deliv_fail, static fail: $static_fail, ai fail: $ai_fail"
  } >> "$summary_file"
}

prereq="${GATE_PREREQS[$GATE]:-}"
if [[ -n "$prereq" && -f "$PHASE_FILE" && -f "$YAML_PARSER" ]]; then
  prereq_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "gates.${prereq}.status" 2>/dev/null || echo "pending")
  if [[ "$prereq_status" != "passed" && "$prereq_status" != "skipped" ]]; then
    echo "エラー: 前提ゲート $prereq が未通過です (status: $prereq_status)" >&2
    echo "$prereq を先に通過させてください" >&2
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$GATE" "fail" 0 0 "$prereq"
    fi
    exit "$EXIT_PREREQ_ERROR"
  fi
fi

# --- ゲート名を取得 ---
gate_name=$(
  python3 - "$GATE_CHECKS" "$GATE" <<'PY'
import re, sys

gate_checks = sys.argv[1]
gate = sys.argv[2]

with open(gate_checks, "r", encoding="utf-8") as fp:
    lines = fp.readlines()

in_gate = False
gate_header = re.compile(rf"^\s*{re.escape(gate)}:\s*$")
next_gate_header = re.compile(r"^G[0-9]+([.][0-9]+)?[A-Z]?:\s*$")

for line in lines:
    stripped = line.strip()
    if not in_gate:
        if gate_header.match(line):
            in_gate = True
        continue
    if next_gate_header.match(stripped):
        break
    m = re.match(r'\s*name:\s*"([^"]+)"', line)
    if m:
        print(m.group(1))
        break
PY
)
gate_name="${gate_name:-$GATE}"

echo ""
echo "=== $GATE: $gate_name ==="
echo ""

if [[ "$GATE" == "G7" ]]; then
  echo "[helix-gate] デプロイ前チェックリスト:"
  echo "  □ staging 環境でのスモークテスト完了"
  echo "  □ ロールバック手順の確認"
  echo "  □ DB マイグレーションの rehearsal 完了"
  echo "  □ 監視ダッシュボードの確認"
  echo "  □ リリースノート（D-RELNOTE）の最終確認"
  echo ""
fi

# 実際の実行はここから
run_checks() {
  local gate="$1"
  local started_ms
  started_ms=$(now_ms)
  local deliv_fail=0
  local static_pass=0
  local static_fail=0
  local static_skip=0
  local mandatory_pass=0
  local mandatory_fail=0
  local advisory_pass=0
  local advisory_fail=0
  local ai_pass=0
  local ai_fail=0
  # deliverable check の前に state を自動更新
  if [[ -f "$HELIX_DIR/matrix.yaml" ]]; then
    local state_file="$HELIX_DIR/state/deliverables.json"
    cp "$state_file" "$state_file.prev" 2>/dev/null || true
    python3 "$SCRIPT_DIR/lib/matrix_compiler.py" --project-root "$PROJECT_ROOT" auto-detect 2>/dev/null || true
    HELIX_STATE_PREV="$state_file.prev" HELIX_STATE_CURR="$state_file" python3 - <<'PY' 2>/dev/null || true
import json
import os


def collect_statuses(payload):
    statuses = {}
    features = payload.get("features", {})
    if not isinstance(features, dict):
        return statuses
    for feature_id, feature in features.items():
        if not isinstance(feature, dict):
            continue
        deliverables = feature.get("deliverables", {})
        if not isinstance(deliverables, dict):
            continue
        for did, entry in deliverables.items():
            if not isinstance(entry, dict):
                continue
            statuses[f"{feature_id}/{did}"] = str(entry.get("status", "pending"))
    return statuses


prev_path = os.environ.get("HELIX_STATE_PREV", "")
curr_path = os.environ.get("HELIX_STATE_CURR", "")
if not prev_path or not curr_path:
    raise SystemExit(0)
if not os.path.exists(prev_path) or not os.path.exists(curr_path):
    raise SystemExit(0)

with open(prev_path, "r", encoding="utf-8") as fp:
    prev = json.load(fp)
with open(curr_path, "r", encoding="utf-8") as fp:
    curr = json.load(fp)

prev_status = collect_statuses(prev)
curr_status = collect_statuses(curr)
drifted = sorted(
    key for key, old_status in prev_status.items()
    if old_status == "done" and curr_status.get(key) == "pending"
)
if drifted:
    print("[helix-gate] WARN: auto-detect により done → pending へ戻った成果物があります")
    for item in drifted[:10]:
        print(f"[helix-gate]   - {item}")
    if len(drifted) > 10:
        print(f"[helix-gate]   ... +{len(drifted) - 10} 件")
PY
  fi

  # --- Deliverable Check ---
  local index_file="$HELIX_DIR/runtime/index.json"
  local state_file="$HELIX_DIR/state/deliverables.json"
  if [[ -f "$index_file" && -f "$state_file" ]]; then
    echo "[deliverable]"
    if python3 "$DELIVERABLE_GATE" --index "$index_file" --state "$state_file" --gate "$gate"; then
      echo ""
    else
      deliv_fail=1
      echo ""
    fi
  fi

  # G2/G4 ミニレトロの記入チェック
  if [[ "$gate" == "G6" ]]; then
    for retro in "$HELIX_DIR"/retros/*-G4.md; do
      [[ -f "$retro" ]] || continue
      if grep -qE '^-\s*$' "$retro" 2>/dev/null; then
        echo "  WARN: レトロ未記入: $(basename "$retro")"
        echo "    Keep/Problem/Try を記入してください"
      fi
    done
  fi

  # --- Fullstack Twin Track Check ---
  if [[ -f "$PHASE_FILE" ]]; then
    local drive
    drive=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.drive" 2>/dev/null || echo "")
    if [[ "$drive" == "fullstack" && ("$gate" == "G3" || "$gate" == "G4") ]]; then
      echo "[fullstack]"
      # G4: BE/FE 両 track の stage が .5 かつ status が completed であること
      if [[ "$gate" == "G4" ]]; then
        local be_stage fe_stage contract_ci be_status fe_status
        be_stage=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.be.stage" 2>/dev/null || echo "")
        fe_stage=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.fe.stage" 2>/dev/null || echo "")
        be_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.be.status" 2>/dev/null || echo "")
        fe_status=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.fe.status" 2>/dev/null || echo "")
        contract_ci=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.tracks.contract.ci" 2>/dev/null || echo "")

        local twin_fail=0
        if [[ "$be_stage" != ".5" || "$be_status" != "completed" ]]; then
          echo "  FAIL: BE Track 未完了 (stage=$be_stage, status=$be_status)"
          twin_fail=1
        fi
        if [[ "$fe_stage" != ".5" || "$fe_status" != "completed" ]]; then
          echo "  FAIL: FE Track 未完了 (stage=$fe_stage, status=$fe_status)"
          twin_fail=1
        fi
        if [[ "$contract_ci" != "pass" ]]; then
          echo "  FAIL: Contract CI 未通過 (ci=$contract_ci)"
          twin_fail=1
        fi
        if [[ $twin_fail -gt 0 ]]; then
          deliv_fail=$((deliv_fail + twin_fail))
          echo "  fullstack G4: FAIL"
        else
          echo "  fullstack G4: BE .5 ✓ FE .5 ✓ Contract CI ✓"
        fi
        echo ""
      fi
    fi
  fi

  if [[ "$AI_ONLY" != true ]]; then
    echo "[static]"
    local check_name=""
    local check_cmd=""
    local check_level="advisory"

    run_static_check() {
      local level="$1"
      local passed=false
      local level_label=""
      if [[ "$level" != "mandatory" && "$level" != "advisory" ]]; then
        level="advisory"
      fi

      if [[ "$level" == "mandatory" ]]; then
        level_label="mandatory"
      else
        level_label="advisory"
      fi

      if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run][$level_label] $check_name: $check_cmd"
        return
      fi

      if (cd "$PROJECT_ROOT" && bash -c "$check_cmd") >/dev/null 2>&1; then
        passed=true
      fi

      if [[ "$level" == "mandatory" ]]; then
        if [[ "$passed" == true ]]; then
          echo "  PASS [mandatory]: $check_name"
          mandatory_pass=$((mandatory_pass + 1))
          static_pass=$((static_pass + 1))
        else
          echo "  FAIL [mandatory]: $check_name"
          echo "    cmd: $check_cmd"
          mandatory_fail=$((mandatory_fail + 1))
          static_fail=$((static_fail + 1))
        fi
      else
        if [[ "$passed" == true ]]; then
          echo "  PASS [advisory]: $check_name"
          advisory_pass=$((advisory_pass + 1))
          static_pass=$((static_pass + 1))
        else
          echo "  WARN [advisory]: $check_name"
          echo "    cmd: $check_cmd"
          advisory_fail=$((advisory_fail + 1))
          static_skip=$((static_skip + 1))
        fi
      fi
    }

    # gate-checks.yaml からこのゲートの static チェックを抽出・実行（PyYAML 非依存）
    local static_rows=()
    while IFS= read -r row; do
      static_rows+=("$row")
    done < <(
      python3 - "$GATE_CHECKS" "$gate" <<'PY'
import re
import sys

def parse_scalar(raw):
    text = raw.strip()
    if len(text) >= 2 and text[0] == '"' and text[-1] == '"':
        inner = text[1:-1]
        inner = inner.replace('\\\\', '\x00').replace('\\"', '"').replace('\\n', '\n').replace('\\t', '\t')
        return inner.replace('\x00', '\\')
    if len(text) >= 2 and text[0] == "'" and text[-1] == "'":
        return text[1:-1]
    return text

gate_checks = sys.argv[1]
gate = sys.argv[2]

with open(gate_checks, "r", encoding="utf-8") as fp:
    lines = fp.readlines()

in_gate = False
in_static = False
current = None
rows = []
gate_header = re.compile(rf"^\s*{re.escape(gate)}:\s*$")
next_gate_header = re.compile(r"^G[0-9]+([.][0-9]+)?[A-Z]?:\s*$")

for line in lines:
    stripped = line.strip()

    if not in_gate:
        if gate_header.match(line):
            in_gate = True
        continue

    if next_gate_header.match(stripped):
        break

    if stripped == "static:":
        in_static = True
        continue

    if not in_static:
        continue

    if stripped == "ai:":
        break

    if not stripped or stripped.startswith("#"):
        continue

    m_name = re.match(r'^\s*-\s*name:\s*(.+)\s*$', line)
    if m_name:
        if isinstance(current, dict) and current.get("cmd"):
            rows.append(current)
        current = {"name": parse_scalar(m_name.group(1)), "cmd": "", "level": "advisory"}
        continue

    if not isinstance(current, dict):
        continue

    m_field = re.match(r"^\s*(cmd|level):\s*(.+)\s*$", line)
    if m_field:
        key = m_field.group(1)
        current[key] = parse_scalar(m_field.group(2))

if isinstance(current, dict) and current.get("cmd"):
    rows.append(current)

for check in rows:
    name = str(check.get("name", "")).replace("\n", " ").replace("\x1f", " ")
    cmd = str(check.get("cmd", "")).replace("\x1f", " ")
    level = str(check.get("level", "advisory")).strip().lower()
    if level not in ("mandatory", "advisory"):
        level = "advisory"
    print(f"{name}\x1f{cmd}\x1f{level}")
PY
    )

    for row in "${static_rows[@]}"; do
      IFS=$'\x1f' read -r check_name check_cmd check_level <<< "$row"
      [[ -n "$check_cmd" ]] || continue
      run_static_check "$check_level"
    done

    local mandatory_total advisory_total mandatory_ok static_total
    mandatory_total=$((mandatory_pass + mandatory_fail))
    advisory_total=$((advisory_pass + advisory_fail))
    mandatory_ok=$((mandatory_total - mandatory_fail))
    static_total=$((mandatory_total + advisory_total))

    if [[ $static_total -eq 0 ]]; then
      echo "  (static チェックなし)"
    else
      echo ""
      if [[ $mandatory_fail -gt 0 ]]; then
        echo "  FAIL (mandatory: $mandatory_ok/$mandatory_total - $mandatory_fail mandatory check failed, advisory: $advisory_pass/$advisory_total)"
      else
        echo "  PASS (mandatory: $mandatory_ok/$mandatory_total, advisory: $advisory_pass/$advisory_total)"
      fi
    fi
    echo ""
  fi

  # --- AI チェック ---
  if [[ "$STATIC_ONLY" != true ]]; then
    echo "[helix-gate] TL レビュー（Codex 5.4）"
    echo "[ai]"

    local ai_rows=()
    local ai_count=0

    run_ai_check() {
      local role="$1"
      local task="$2"

      ai_count=$((ai_count + 1))
      if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] helix-codex --role $role --task \"${task:0:60}...\""
        return
      fi

      echo "  実行中: helix-codex --role $role ..."
      local ai_output_file
      ai_output_file=$(mktemp "${TMPDIR:-/tmp}/helix-gate-ai-XXXXXX")

      set +e
      "$HELIX_CODEX" --role "$role" --task "$task" >"$ai_output_file" 2>&1
      local ai_exit=$?
      set -e

      cat "$ai_output_file"

      local verdict=""
      verdict=$(grep -Eo '"verdict"[[:space:]]*:[[:space:]]*"(approve|needs-attention)"' "$ai_output_file" | head -n1 | sed -E 's/.*"(approve|needs-attention)"/\1/' || true)

      if [[ "$verdict" == "needs-attention" ]]; then
        ai_fail=$((ai_fail + 1))
        echo "  [ai] FAIL: $role (verdict: needs-attention)"
      elif [[ -n "$verdict" ]]; then
        ai_pass=$((ai_pass + 1))
      elif [[ "$ai_exit" -eq 0 ]]; then
        ai_pass=$((ai_pass + 1))
      else
        ai_fail=$((ai_fail + 1))
        echo "  [ai] FAIL: $role"
      fi

      rm -f "$ai_output_file"
      echo ""
    }

    while IFS= read -r row; do
      ai_rows+=("$row")
    done < <(
      python3 - "$GATE_CHECKS" "$gate" <<'PY'
import re
import sys

def parse_scalar(raw):
    text = raw.strip()
    if len(text) >= 2 and text[0] == '"' and text[-1] == '"':
        inner = text[1:-1]
        inner = inner.replace('\\\\', '\x00').replace('\\"', '"').replace('\\n', '\n').replace('\\t', '\t')
        return inner.replace('\x00', '\\')
    if len(text) >= 2 and text[0] == "'" and text[-1] == "'":
        return text[1:-1]
    return text

gate_checks = sys.argv[1]
gate = sys.argv[2]

with open(gate_checks, "r", encoding="utf-8") as fp:
    lines = fp.readlines()

in_gate = False
in_ai = False
current_role = ""
current_task_lines = []
capture_task = False
task_indent = 0
content_indent = None
rows = []

gate_header = re.compile(rf"^\s*{re.escape(gate)}:\s*$")
next_gate_header = re.compile(r"^G[0-9]+([.][0-9]+)?[A-Z]?:\s*$")

def flush_current():
    if current_role and current_task_lines:
        task = "\n".join(current_task_lines).rstrip()
        if task:
            print(f"{current_role}\x1f{task}")

for line in lines:
    stripped = line.strip()
    indent = len(line) - len(line.lstrip(" "))

    if not in_gate:
        if gate_header.match(line):
            in_gate = True
        continue

    if next_gate_header.match(stripped):
        break

    if stripped == "ai:":
        in_ai = True
        continue

    if not in_ai:
        continue

    role_match = re.match(r"^\s*-\s*role:\s*(.+)\s*$", line)
    if role_match:
        flush_current()
        current_role = parse_scalar(role_match.group(1))
        current_task_lines = []
        capture_task = False
        task_indent = 0
        content_indent = None
        continue

    task_block_match = re.match(r"^(\s*)task:\s*\|\s*$", line)
    if task_block_match and current_role:
        capture_task = True
        task_indent = len(task_block_match.group(1))
        content_indent = None
        continue

    task_inline_match = re.match(r"^\s*task:\s*(.+)\s*$", line)
    if task_inline_match and current_role:
        current_task_lines = [parse_scalar(task_inline_match.group(1))]
        capture_task = False
        continue

    if capture_task:
        if stripped == "":
            current_task_lines.append("")
            continue
        if indent <= task_indent:
            capture_task = False
            continue
        if content_indent is None and stripped:
            content_indent = indent
        if content_indent is None:
            current_task_lines.append("")
        else:
            current_task_lines.append(line[content_indent:].rstrip("\n"))

flush_current()
PY
    )

    for row in "${ai_rows[@]}"; do
      local ai_role ai_task
      IFS=$'\x1f' read -r ai_role ai_task <<< "$row"
      [[ -n "$ai_role" && -n "$ai_task" ]] || continue
      run_ai_check "$ai_role" "$ai_task"
    done

    if [[ $ai_count -eq 0 ]]; then
      echo "  (AI チェックなし)"
    else
      echo "  ai: $ai_pass pass, $ai_fail fail"
    fi
  fi

  # --- 総合判定 ---
  local total_fail=$((deliv_fail + mandatory_fail + ai_fail))
  local ended_ms duration_ms result
  ended_ms=$(now_ms)
  duration_ms=$((ended_ms - started_ms))
  if [[ $total_fail -gt 0 ]]; then
    result="fail"
  else
    result="pass"
  fi
  if [[ "$DRY_RUN" != true ]]; then
    log_gate_run "$gate" "$result" "$deliv_fail" "$static_fail" "$ai_fail" "$duration_ms"
  fi
  echo ""
  if [[ $total_fail -gt 0 ]]; then
    echo "=== $gate FAIL (deliverable: $deliv_fail fail, mandatory: $mandatory_fail fail, advisory: $advisory_fail fail, ai: $ai_fail fail) ==="
    if [[ "$DRY_RUN" != true ]]; then
      log_gate_summary "$gate" "$result" "$deliv_fail" "$static_fail" "$ai_fail"
    fi
    if [[ "$DRY_RUN" != true && -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.status" "failed" 2>/dev/null || true
    fi
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$gate" "fail" "$static_pass" "$static_fail" "$prereq"
    fi
    exit "$EXIT_CHECK_FAILED"
  else
    echo "=== $gate PASS ==="
    if [[ "$DRY_RUN" != true ]]; then
      log_gate_summary "$gate" "$result" "$deliv_fail" "$static_fail" "$ai_fail"
    fi
    if [[ "$DRY_RUN" != true && -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.status" "passed" 2>/dev/null || true
      python3 "$YAML_PARSER" write "$PHASE_FILE" "gates.${gate}.date" "$(date '+%Y-%m-%d')" 2>/dev/null || true
      maybe_generate_retro "$gate"
    fi
    case "$gate" in
      G4)
        echo ""
        echo "[helix-gate] 品質改善の提案:"

        # TODO/FIXME/HACK/WORKAROUND の残存数を集計
        todo_count=$( (rg -c 'TODO|FIXME|HACK|WORKAROUND' src/ 2>/dev/null || true) | awk -F: '{s+=$2}END{print s+0}' )
        if [[ $todo_count -gt 0 ]]; then
          echo "  TODO/FIXME: $todo_count 件 → helix debt add で台帳化を推奨"
        fi

        # 負債台帳の未解決件数サマリ
        if [[ -f "$HELIX_DIR/debt-register.yaml" ]]; then
          debt_count=$(grep -c "status: open" "$HELIX_DIR/debt-register.yaml" 2>/dev/null || true)
          debt_count="${debt_count:-0}"
          echo "  技術負債: $debt_count 件（未解決）→ 次イテレーション 20% 枠で対応推奨"
        fi

        echo "  helix promote --auto で昇格候補を確認"
        echo "  helix bench で品質推移を確認"
        echo "次のアクション: helix gate G5 または helix gate G6 に進んでください"
        echo "[helix-gate] ヒント: 'helix promote --auto' で昇格候補を確認できます"
        ;;
      G6)
        echo "[helix-gate] ヒント: E2E テストを実行してください"
        echo "  npx playwright test（Playwright）"
        echo "  npm test -- --coverage（Jest）"
        echo "  pytest --cov（pytest）"
        echo "次のアクション: helix gate G7 → helix pr でリリース準備"
        ;;
      G7)
        echo "次のアクション: helix pr で PR を作成してください"
        echo ""
        echo "[helix-gate] L8 受入準備:"
        echo "  受入条件（D-ACC）と実装の突合を実施してください"
        echo "  helix matrix status で全成果物の状態を確認"
        ;;
    esac
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$gate" "pass" "$static_pass" "$static_fail" "$prereq"
    fi
  fi
}

# --- ミニレトロ自動生成 ---
maybe_generate_retro() {
  local gate="$1"
  local phase_desc=""

  case "$gate" in
    G2) phase_desc="設計フェーズ (L1-L2)" ;;
    G4) phase_desc="実装フェーズ (L3-L4)" ;;
    *)  return ;;
  esac

  local retro_dir="$HELIX_DIR/retros"
  mkdir -p "$retro_dir"
  local today
  today=$(date '+%Y-%m-%d')
  local retro_file="$retro_dir/${today}-${gate}.md"

  if [[ -f "$retro_file" ]]; then
    echo ""
    echo "[helix-gate] Retro already exists: $retro_file"
    return
  fi

  local template="$SCRIPT_DIR/templates/retro.md.template"
  if [[ -f "$template" ]]; then
    sed -e "s/{{GATE}}/$gate/g" \
        -e "s/{{DATE}}/$today/g" \
        -e "s/{{PHASE_DESC}}/$phase_desc/g" \
        "$template" > "$retro_file"
  else
    cat > "$retro_file" <<RETRO
# Mini Retro: $gate ($today)

## Phase: $phase_desc

### Keep（うまくいったこと）
-

### Problem（問題があったこと）
-

### Try（次に試すこと）
| アクション | 担当 | 期日 |
|-----------|------|------|
| | | |
RETRO
  fi

  echo ""
  echo "[helix-gate] ミニレトロ生成: $retro_file"
  echo "[helix-gate]   内容を記入してください（Try は owner + due 必須）"
}

run_checks "$GATE"
