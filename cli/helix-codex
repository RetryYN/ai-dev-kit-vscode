#!/bin/bash
set -euo pipefail

# helix-codex: HELIX スキル注入付き Codex CLI ラッパー
# Usage: helix-codex --role <role> --task "タスク内容" [--thinking <level>]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
ROLES_DIR="$SCRIPT_DIR/roles"
SKILLS_DIR="$HELIX_HOME/skills"
PROJECT_GENERATED_SKILLS_DIR="$PROJECT_ROOT/skills/generated"
PROJECT_SKILLS_DIR="$PROJECT_ROOT/skills"
PROJECT_CLAUDE_SKILLS_DIR="$PROJECT_ROOT/.claude/skills"
CODEX_BIN="${CODEX_BIN:-$(command -v codex 2>/dev/null || echo "$HOME/.npm-global/bin/codex")}"

# --- パス検証ユーティリティ ---
ROLES_DIR_REAL="$(realpath "$ROLES_DIR")"
SKILLS_DIR_REAL="$(realpath "$SKILLS_DIR")"
HELIX_HOME_REAL="$(realpath "$HELIX_HOME")"
PROJECT_GENERATED_SKILLS_DIR_REAL="$(realpath -m "$PROJECT_GENERATED_SKILLS_DIR")"
PROJECT_SKILLS_DIR_REAL="$(realpath -m "$PROJECT_SKILLS_DIR")"
PROJECT_CLAUDE_SKILLS_DIR_REAL="$(realpath -m "$PROJECT_CLAUDE_SKILLS_DIR")"

ensure_within_dir() {
  local target="$1"
  local base="$2"
  local label="$3"
  if [[ "$target" != "$base" && "$target" != "$base/"* ]]; then
    echo "エラー: 無効な ${label} パスです（許可ディレクトリ外）: $target" >&2
    exit 1
  fi
}

# --- 引数パース ---
ROLE=""
TASK=""
TASK_FILE=""
THINKING=""
THINKING_EXPLICIT=false
AUTO_THINKING=false
DRY_RUN=false
SANDBOX="workspace-write"
FULL_AUTO=""
TIMEOUT=300
MAX_RETRY=2          # GAP-038: デフォルトはロール別後続で上書き
FALLBACK_MODEL=""    # GAP-038 Phase 2: Layer 2 代替モデル

while [[ $# -gt 0 ]]; do
  case $1 in
    --role)            ROLE="$2"; shift 2 ;;
    --task)            TASK="$2"; shift 2 ;;
    --task-file)       TASK_FILE="$2"; shift 2 ;;
    --thinking)        THINKING="$2"; THINKING_EXPLICIT=true; shift 2 ;;
    --auto-thinking)   AUTO_THINKING=true; shift ;;
    --timeout)         TIMEOUT="$2"; shift 2 ;;
    --max-retries)     MAX_RETRY="$2"; shift 2 ;;
    --fallback-model)  FALLBACK_MODEL="$2"; shift 2 ;;
    --sandbox)         SANDBOX="$2"; shift 2 ;;
    --read-only)       SANDBOX="read-only"; shift ;;
    --full-auto)       FULL_AUTO="--full-auto"; shift ;;
    --dry-run)         DRY_RUN=true; shift ;;
    --help|-h)
      echo "使い方: helix codex --role <role> (--task \"タスク\" | --task-file <path>)"
      echo ""
      echo "Options:"
      echo "  --role <role>            ロール（tl/se/pg/fe/qa/security/dba/devops/docs/research/legacy/perf）"
      echo "  --task \"...\"             タスク内容（文字列）"
      echo "  --task-file <path>       タスク内容をファイルから読む（大きなプロンプト向け、ARG_MAX 回避）"
      echo "  --thinking <level>       思考レベル（low/medium/high/xhigh）。省略時はロール別デフォルト"
      echo "  --auto-thinking          タスク難度から thinking を自動推定（--thinking と併用時は手動優先）"
      echo "  --timeout <sec>          codex exec タイムアウト秒（デフォルト: 300）"
      echo "  --max-retries <n>        最大リトライ回数（デフォルト: 2、0 でリトライなし）"
      echo "  --fallback-model <name>  Codex 失敗時の代替モデル（例: gpt-5.2-codex）"
      echo "  --sandbox    サンドボックスモード (read-only|workspace-write|danger-full-access)"
      echo "               デフォルト: workspace-write"
      echo "  --read-only  --sandbox read-only のショートカット"
      echo "  --full-auto          承認なしで自律実行"
      echo "  --dry-run    実行せずプロンプトだけ表示"
      echo ""
      echo "Roles:"
      for f in "$ROLES_DIR"/*.conf; do
        basename "$f" .conf
      done
      exit 0
      ;;
    *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
  esac
done

# --- --task と --task-file の排他チェック ---
if [[ -n "$TASK" && -n "$TASK_FILE" ]]; then
  echo "エラー: --task と --task-file は同時指定できません" >&2
  exit 1
fi

# --- --task-file 読み込み ---
if [[ -n "$TASK_FILE" ]]; then
  if [[ ! -f "$TASK_FILE" ]]; then
    echo "エラー: --task-file が見つかりません: $TASK_FILE" >&2
    exit 1
  fi
  if [[ ! -r "$TASK_FILE" ]]; then
    echo "エラー: --task-file を読み込めません: $TASK_FILE" >&2
    exit 1
  fi
  TASK=$(cat "$TASK_FILE")
fi

# --- max_retries バリデーション ---
if ! [[ "$MAX_RETRY" =~ ^[0-9]+$ ]] || [[ "$MAX_RETRY" -gt 10 ]]; then
  echo "エラー: 無効な --max-retries 値です: '$MAX_RETRY'（0-10 の整数を指定）" >&2
  exit 1
fi

if [[ -z "$ROLE" || -z "$TASK" ]]; then
  echo "エラー: --role と --task は必須です" >&2
  echo "--help で使い方を確認してください" >&2
  exit 1
fi

# --- ロール名バリデーション ---
if [[ ! "$ROLE" =~ ^[a-z0-9_-]+$ ]]; then
  echo "エラー: 無効な --role 値です: '$ROLE'（許可パターン: ^[a-z0-9_-]+$）" >&2
  exit 1
fi

# --- thinking level バリデーション ---
if [[ -n "$THINKING" ]]; then
  case "$THINKING" in
    low|medium|high|xhigh) ;;
    *)
      echo "エラー: 無効な --thinking 値です: '$THINKING'（有効値: low|medium|high|xhigh）" >&2
      exit 1
      ;;
  esac
fi

# --thinking 未指定時のロール別デフォルト
get_default_thinking() {
  local role="$1"
  case "$role" in
    tl|security)   echo "xhigh" ;;
    se|fe|qa|perf) echo "high" ;;
    pg|dba|devops) echo "medium" ;;
    docs|research) echo "low" ;;
    legacy)        echo "xhigh" ;;
    *)             echo "high" ;;
  esac
}

# 注: THINKING の決定は ROLE_FILE 読み込み後に行う
# (CLI --thinking > conf の codex_thinking > ロール別デフォルト の優先順位)

if [[ ! "$TIMEOUT" =~ ^[0-9]+$ || "$TIMEOUT" -le 0 ]]; then
  echo "エラー: 無効な --timeout 値です: '$TIMEOUT'（正の整数秒を指定）" >&2
  exit 1
fi

# --- ロール設定読み込み ---
ROLE_FILE="$ROLES_DIR/${ROLE}.conf"
ROLE_FILE_REAL="$(realpath -m "$ROLE_FILE")"
ensure_within_dir "$ROLE_FILE_REAL" "$ROLES_DIR_REAL" "role file"

if [[ ! -f "$ROLE_FILE_REAL" ]]; then
  echo "エラー: ロールが見つかりません: $ROLE" >&2
  echo "利用可能なロール:" >&2
  for f in "$ROLES_DIR"/*.conf; do
    basename "$f" .conf >&2
  done
  exit 1
fi

# conf ファイルから値を抽出
codex_model=$(grep '^codex_model=' "$ROLE_FILE_REAL" | cut -d= -f2 || true)
codex_thinking=$(grep '^codex_thinking=' "$ROLE_FILE_REAL" | cut -d= -f2 || true)
system_prompt=$(grep '^system_prompt=' "$ROLE_FILE_REAL" | sed 's/^system_prompt="//' | sed 's/"$//' || true)

if [[ -z "$codex_model" ]]; then
  echo "エラー: $ROLE_FILE_REAL に codex_model が定義されていません" >&2
  exit 1
fi

# --- THINKING 決定 (CLI --thinking > conf の codex_thinking > ロール別デフォルト) ---
if [[ -z "$THINKING" ]]; then
  if [[ -n "$codex_thinking" ]]; then
    THINKING="$codex_thinking"
  else
    THINKING="$(get_default_thinking "$ROLE")"
  fi
fi

# --- auto-thinking: タスク難度から thinking を自動推定 ---
if [[ "$AUTO_THINKING" == true ]]; then
  AUTO_RESULT=$(python3 - <<PY 2>/dev/null || echo ""
import sys
sys.path.insert(0, "$SCRIPT_DIR/lib")
from effort_classifier import classify
r = classify(${TASK@Q}, role=${ROLE@Q}, size=None, files=None, lines=None, use_llm=False)
print(f"{r['recommended_thinking']}|effort={r['effort']}|score={r['score']}")
PY
)
  if [[ -n "$AUTO_RESULT" ]]; then
    AUTO_THINKING_LEVEL="${AUTO_RESULT%%|*}"
    AUTO_DETAILS="${AUTO_RESULT#*|}"
    if [[ "$THINKING_EXPLICIT" == true && "$THINKING" != "$AUTO_THINKING_LEVEL" ]]; then
      echo "[auto-thinking] 手動 --thinking=$THINKING 優先 (自動推定=$AUTO_THINKING_LEVEL, $AUTO_DETAILS)" >&2
    else
      echo "[auto-thinking] thinking=$AUTO_THINKING_LEVEL ($AUTO_DETAILS)" >&2
      THINKING="$AUTO_THINKING_LEVEL"
    fi
  else
    echo "[auto-thinking] warning: classifier 失敗、ロール既定 thinking=$THINKING 使用" >&2
  fi
fi

# --- 配列抽出関数 ---
parse_array() {
  local key="$1"
  local file="$2"
  local in_array=false
  while IFS= read -r line; do
    if [[ "$line" == "${key}=(" ]]; then
      in_array=true
      continue
    fi
    if [[ "$in_array" == true ]]; then
      if [[ "$line" == ")" ]]; then
        break
      fi
      local item
      item=$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
      if [[ -n "$item" ]]; then
        echo "$item"
      fi
    fi
  done < "$file"
}

resolve_skill_file() {
  local skill="$1"
  local -a candidates=(
    "$PROJECT_GENERATED_SKILLS_DIR/$skill/SKILL.md"
    "$PROJECT_SKILLS_DIR/$skill/SKILL.md"
    "$PROJECT_CLAUDE_SKILLS_DIR/$skill/SKILL.md"
    "$SKILLS_DIR/$skill/SKILL.md"
  )
  local -a bases=(
    "$PROJECT_GENERATED_SKILLS_DIR_REAL"
    "$PROJECT_SKILLS_DIR_REAL"
    "$PROJECT_CLAUDE_SKILLS_DIR_REAL"
    "$SKILLS_DIR_REAL"
  )
  local candidate
  local candidate_real
  local i

  for i in "${!candidates[@]}"; do
    candidate="${candidates[$i]}"
    candidate_real="$(realpath -m "$candidate")"
    ensure_within_dir "$candidate_real" "${bases[$i]}" "skill"
    if [[ -f "$candidate_real" ]]; then
      echo "$candidate_real"
      return 0
    fi
  done

  return 1
}

# --- スキルパス一覧を構築 ---
SKILL_PATHS=""
LOADED_SKILLS=()
while IFS= read -r skill; do
  [[ -z "$skill" ]] && continue
  if skill_file_real="$(resolve_skill_file "$skill")"; then
    SKILL_PATHS+="- $skill_file_real
"
    if grep -Eq '^[[:space:]]*verified:[[:space:]]*false([[:space:]]|$)' "$skill_file_real" 2>/dev/null; then
      echo "[helix-codex] WARN: $skill は未検証のスキルです" >&2
    fi
    LOADED_SKILLS+=("$skill")
  else
    echo "警告: スキルが見つかりません（overlay/global 検索順）: $skill" >&2
  fi
done < <(parse_array "skills" "$ROLE_FILE_REAL")

# --- 共通ドキュメントパス一覧を構築 ---
COMMON_DOC_PATHS=""
LOADED_DOCS=()
while IFS= read -r doc; do
  [[ -z "$doc" ]] && continue
  doc_file="$HELIX_HOME/$doc"
  doc_file_real="$(realpath -m "$doc_file")"
  ensure_within_dir "$doc_file_real" "$HELIX_HOME_REAL" "common doc"
  if [[ -f "$doc_file_real" ]]; then
    COMMON_DOC_PATHS+="- $doc_file_real
"
    LOADED_DOCS+=("$doc")
  else
    echo "警告: 共通ドキュメントが見つかりません: $doc_file" >&2
  fi
done < <(parse_array "common_docs" "$ROLE_FILE_REAL")

# --- プロンプト構築 ---
PROMPT="$system_prompt

## 共通参照（作業前に必ず Read すること）
$COMMON_DOC_PATHS
## 参照スキル（タスクに該当するもののみ Read。全部読むな。不要なスキルは飛ばせ）
$SKILL_PATHS
## タスク
$TASK"

# --- 実行 ---
if [[ "$DRY_RUN" == true ]]; then
  echo "=== helix-codex dry-run ==="
  echo "Role:      $ROLE"
  echo "Model:     $codex_model"
  echo "Thinking:  $THINKING"
  echo "Timeout:   $TIMEOUT"
  echo "Sandbox:   $SANDBOX"
  echo "Full-Auto: ${FULL_AUTO:-off}"
  echo "Skills:    ${LOADED_SKILLS[*]:-none}"
  echo "Docs:      ${LOADED_DOCS[*]:-none}"
  echo "Prompt:    $(echo "$PROMPT" | wc -c) bytes"
  echo "=== Full prompt ==="
  echo "$PROMPT"
  exit 0
fi

# L2/L3 設計タスクの場合、plan finalized チェック
if [[ "$ROLE" == "tl" || "$ROLE" == "se" ]]; then
  YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
  PHASE_FILE="$PROJECT_ROOT/.helix/phase.yaml"
  if [[ -f "$YAML_PARSER" && -f "$PHASE_FILE" ]]; then
    current_phase=$(python3 "$YAML_PARSER" read "$PHASE_FILE" "current_phase" 2>/dev/null || echo "")
    if [[ "$current_phase" == "L2" || "$current_phase" == "L3" ]]; then
      shopt -s nullglob
      plan_files=("$PROJECT_ROOT/.helix/plans"/PLAN-*.yaml)
      shopt -u nullglob
      plan_count=${#plan_files[@]}
      finalized=0
      for plan_file in "${plan_files[@]}"; do
        if grep -q "^status: finalized" "$plan_file" 2>/dev/null; then
          finalized=$((finalized + 1))
        fi
      done
      if [[ $plan_count -gt 0 && $finalized -eq 0 ]]; then
        echo "[helix-codex] 警告: 未確定の設計提案があります。helix plan finalize で確定してください" >&2
      fi
    fi
  fi
fi

if [[ ! -x "$CODEX_BIN" ]]; then
  echo "エラー: codex が見つかりません: $CODEX_BIN" >&2
  echo "CODEX_BIN 環境変数を設定するか、codex をインストールしてください" >&2
  exit 1
fi

echo "[helix-codex] role=$ROLE model=$codex_model thinking=$THINKING sandbox=$SANDBOX full_auto=$FULL_AUTO skills=${LOADED_SKILLS[*]:-none} docs=${LOADED_DOCS[*]:-none}" >&2

# --- GAP-038 リジリエンス強化: リトライ + バックオフ + フォールバック ---
# エラー分類:
#   - timeout (exit 124)    : 即リトライ（バックオフなし）
#   - network (exit 7-8)    : エクスポネンシャルバックオフ（1s, 2s, 4s ...）
#   - その他                : 標準バックオフ（1秒）
classify_codex_error() {
  local code="$1"
  case "$code" in
    124)     echo "timeout" ;;
    7|8|28)  echo "network" ;;  # curl-style exit codes
    *)       echo "other" ;;
  esac
}

calculate_backoff() {
  local error_type="$1"
  local attempt="$2"
  case "$error_type" in
    timeout)  echo 0 ;;                            # 即リトライ
    network)  echo $((1 << (attempt - 1))) ;;      # 1, 2, 4, 8 ...（エクスポネンシャル）
    *)        echo 1 ;;                            # 標準
  esac
}

run_codex_once() {
  local model="$1"
  set +e
  timeout "$TIMEOUT" "$CODEX_BIN" exec "$PROMPT" -m "$model" -s "$SANDBOX" \
    --skip-git-repo-check \
    -c "model_reasoning_effort=\"$THINKING\"" \
    -c 'shell_environment_policy.inherit=all' \
    ${FULL_AUTO:+$FULL_AUTO}
  local rc=$?
  set -e
  return $rc
}

# Primary model リトライループ
retry=0
codex_exit=1
active_model="$codex_model"

while [[ $retry -le $MAX_RETRY ]]; do
  run_codex_once "$active_model"
  codex_exit=$?

  if [[ $codex_exit -eq 0 ]]; then
    break
  fi

  retry=$((retry + 1))
  if [[ $retry -le $MAX_RETRY ]]; then
    error_type=$(classify_codex_error "$codex_exit")
    backoff=$(calculate_backoff "$error_type" "$retry")
    echo "[helix-codex] リトライ ($retry/$MAX_RETRY, error=$error_type, backoff=${backoff}s)..." >&2
    if [[ $backoff -gt 0 ]]; then
      sleep "$backoff" 2>/dev/null || true
    fi
  fi
done

# --- Layer 2 フォールバック: Primary 失敗時に代替モデルで1回だけ再試行 ---
if [[ $codex_exit -ne 0 ]] && [[ -n "$FALLBACK_MODEL" ]]; then
  echo "[helix-codex] Primary ($codex_model) 失敗。フォールバック: $FALLBACK_MODEL で再試行" >&2
  active_model="$FALLBACK_MODEL"
  run_codex_once "$active_model"
  codex_exit=$?
  if [[ $codex_exit -eq 0 ]]; then
    echo "[helix-codex] フォールバック成功: $FALLBACK_MODEL" >&2
  else
    echo "[helix-codex] フォールバックも失敗: $FALLBACK_MODEL (exit=$codex_exit)" >&2
  fi
fi

# コスト記録（バックグラウンド）
if [[ -f "$HELIX_DIR/helix.db" ]]; then
  # active_model は Primary または Fallback のどちらが最終的に使われたか
  HELIX_DB_PATH="$HELIX_DIR/helix.db" python3 "$SCRIPT_DIR/lib/helix_db.py" insert cost_log \
    "{\"role\":\"$ROLE\",\"model\":\"$active_model\",\"thinking\":\"$THINKING\",\"retries\":$retry,\"exit_code\":$codex_exit}" 2>/dev/null &
fi

exit $codex_exit
