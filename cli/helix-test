import json
import re
from pathlib import Path

root = Path(".")
index_path = root / ".helix/runtime/index.json"
state_path = root / ".helix/state/deliverables.json"
index = json.loads(index_path.read_text(encoding="utf-8"))
state = json.loads(state_path.read_text(encoding="utf-8"))

rules = index.get("rules", {})
roots = rules.get("roots", {}) if isinstance(rules.get("roots"), dict) else {}
path_mapping = rules.get("path_mapping", {}) if isinstance(rules.get("path_mapping"), dict) else {}

heading_requirements = {}
for item in rules.get("deliverables", []):
    if not isinstance(item, dict):
        continue
    did = item.get("id")
    if not isinstance(did, str):
        continue
    required = []
    for validator in item.get("validators", []):
        if not isinstance(validator, dict):
            continue
        if validator.get("type") != "heading_check":
            continue
        params = validator.get("params", {})
        if isinstance(params, dict):
            values = params.get("required", [])
            if isinstance(values, list):
                required.extend([str(x) for x in values if isinstance(x, str)])
    heading_requirements[did] = required


def render(template: str, values: dict[str, str]) -> str:
    return re.sub(r"{([a-zA-Z0-9_]+)}", lambda m: str(values.get(m.group(1), m.group(0))), template)


features = index.get("features", {})
for feature_id, feature in features.items():
    if not isinstance(feature, dict):
        continue
    requires = feature.get("requires", {})
    if not isinstance(requires, dict):
        continue

