import sqlite3
import tempfile
from datetime import datetime, timezone
from pathlib import Path

from global_store import init_global_db, sync_from_local
from helix_db import init_db

base = Path(tempfile.mkdtemp(prefix="helix-cross-project-"))
now = datetime.now(timezone.utc).isoformat()


def create_project(name: str) -> tuple[Path, str]:
    root = base / name
    db_path = root / ".helix" / "helix.db"
    db_path.parent.mkdir(parents=True, exist_ok=True)
    init_db(str(db_path))

    conn = sqlite3.connect(db_path)
    conn.execute(
        "INSERT INTO task_runs (task_id, task_type, plan_goal, role, status, started_at, completed_at, output_log) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        ("DUP-001", "dup-collision-demo", "cross-project collision test", "se", "completed", now, now, ""),
    )
    run_id = int(conn.execute("SELECT last_insert_rowid()").fetchone()[0])
    conn.execute(
        "INSERT INTO action_logs (task_run_id, action_index, action_type, action_desc, status, evidence) "
        "VALUES (?, ?, ?, ?, ?, ?)",
        (run_id, 1, "search", "query=collision", "passed", '{"query":"collision"}'),
    )
    conn.execute(
        "INSERT INTO action_logs (task_run_id, action_index, action_type, action_desc, status, evidence) "
        "VALUES (?, ?, ?, ?, ?, ?)",
        (run_id, 2, "generate", "target=task", "passed", '{"target":"task"}'),
    )
    conn.execute(
        "INSERT INTO action_logs (task_run_id, action_index, action_type, action_desc, status, evidence) "
        "VALUES (?, ?, ?, ?, ?, ?)",
        (run_id, 3, "verify", "check=output", "passed", '{"check":"output"}'),
    )
    conn.execute(
        "INSERT INTO observations (task_run_id, action_log_id, action_type, expected_keywords, matched_keywords, passed, reason) "
        "VALUES (?, ?, ?, ?, ?, ?, ?)",
        (run_id, None, "verify", "[]", "[]", 1, ""),
    )
    conn.commit()
    conn.close()
    return db_path, f"{name}-project"


