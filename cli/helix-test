PASS=0
FAIL=0
ERRORS=()

run_test() {
  local name="$1"
  local cmd="$2"
  local expect_exit="${3:-0}"
  printf "  %-40s " "$name"
  set +e
  output=$(eval "$cmd" 2>&1 </dev/null)
  actual_exit=$?
  set -e
  if [[ "$actual_exit" -eq "$expect_exit" ]]; then
    echo "PASS"
    PASS=$((PASS + 1))
  else
    echo "FAIL (exit=$actual_exit, expected=$expect_exit)"
    ERRORS+=("$name: $output")
    FAIL=$((FAIL + 1))
  fi
}

run_test_contains() {
  local name="$1"
  local cmd="$2"
  local pattern="$3"
  printf "  %-40s " "$name"
  output=$(eval "$cmd" 2>&1 </dev/null)
  if echo "$output" | grep -q "$pattern"; then
    echo "PASS"
    PASS=$((PASS + 1))
  else
    echo "FAIL (pattern '$pattern' not found)"
    ERRORS+=("$name: output=$output")
    FAIL=$((FAIL + 1))
  fi
}

run_test_not_contains() {
  local name="$1"
  local cmd="$2"
  local pattern="$3"
  printf "  %-40s " "$name"
  output=$(eval "$cmd" 2>&1 </dev/null)
  if echo "$output" | grep -q "$pattern"; then
    echo "FAIL (pattern '$pattern' was found)"
    ERRORS+=("$name: output=$output")
    FAIL=$((FAIL + 1))
  else
    echo "PASS"
    PASS=$((PASS + 1))
  fi
}

