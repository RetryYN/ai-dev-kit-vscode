#!/bin/bash
set -euo pipefail

# helix: HELIX CLI 統一エントリポイント
# Usage: helix <subcommand> [args...]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  init)     exec "$SCRIPT_DIR/helix-init" "$@" ;;
  codex)    exec "$SCRIPT_DIR/helix-codex" "$@" ;;
  team)     exec "$SCRIPT_DIR/helix-team" "$@" ;;
  gate)     exec "$SCRIPT_DIR/helix-gate" "$@" ;;
  size)     exec "$SCRIPT_DIR/helix-size" "$@" ;;
  sprint)   exec "$SCRIPT_DIR/helix-sprint" "$@" ;;
  pr)       exec "$SCRIPT_DIR/helix-pr" "$@" ;;
  reverse)  exec "$SCRIPT_DIR/helix-reverse" "$@" ;;
  mode)     exec "$SCRIPT_DIR/helix-mode" "$@" ;;
  builder)  exec "$SCRIPT_DIR/helix-builder" "$@" ;;
  task)     exec "$SCRIPT_DIR/helix-task" "$@" ;;
  log)      exec "$SCRIPT_DIR/helix-log" "$@" ;;
  debug)    exec "$SCRIPT_DIR/helix-debug" "$@" ;;
  verify-all) exec "$SCRIPT_DIR/helix-verify-all" "$@" ;;
  scrum)    exec "$SCRIPT_DIR/helix-scrum" "$@" ;;
  matrix)   exec "$SCRIPT_DIR/helix-matrix" "$@" ;;
  plan)     exec "$SCRIPT_DIR/helix-plan" "$@" ;;
  interrupt) exec "$SCRIPT_DIR/helix-interrupt" "$@" ;;
  learn)    exec "$SCRIPT_DIR/helix-learn" "$@" ;;
  promote)  exec "$SCRIPT_DIR/helix-promote" "$@" ;;
  discover) exec "$SCRIPT_DIR/helix-discover" "$@" ;;
  skill)    exec "$SCRIPT_DIR/helix-skill" "$@" ;;
  status)   exec "$SCRIPT_DIR/helix-status" "$@" ;;
  test)     exec "$SCRIPT_DIR/helix-test" "$@" ;;
  bench)    exec "$SCRIPT_DIR/helix-bench" "$@" ;;
  retro)    exec "$SCRIPT_DIR/helix-retro" "$@" ;;
  debt)     exec "$SCRIPT_DIR/helix-debt" "$@" ;;
  review)   exec "$SCRIPT_DIR/helix-review" "$@" ;;
  drift-check) exec "$SCRIPT_DIR/helix-drift-check" "$@" ;;
  session-summary) exec "$SCRIPT_DIR/helix-session-summary" "$@" ;;
  doctor)   exec "$SCRIPT_DIR/helix-doctor" "$@" ;;
  help|-h|--help)
    cat <<'USAGE'
使い方: helix <コマンド>

Commands:
プロジェクト管理:
  init        プロジェクト初期化
  status      プロジェクト状態表示
  mode        開発モード切替
  matrix      成果物マトリクス管理
  doctor      環境診断・修復
  debug       デバッグツール

ワークフロー:
  gate        ゲート自動検証
  size        タスクサイジング
  sprint      L4 マイクロスプリント
  plan        設計計画
  reverse     リバース HELIX
  scrum       検証駆動開発
  interrupt   中断・復帰管理

実行・委譲:
  codex       Codex へのタスク委譲
  task        タスクオペレーティングシステム
  team        エージェントチーム実行
  builder     成果物ビルダー
  pr          PR 自動生成
  review      Codex 自動レビュー

データ・学習:
  log         ログ・評価システム
  bench       メトリクスベンチマーク
  debt        技術負債管理
  retro       レトロスペクティブ
  learn       成功パターン学習
  promote     レシピ昇格
  discover    パターン検索

検証:
  test        セルフテスト
  verify-all  全レイヤー検証

スキル管理:
  skill list/show/catalog/search     スキル自動推挙コマンド

Environment:
  HELIX_HOME    HELIX インストールディレクトリ (default: ~/ai-dev-kit-vscode)

Run 'helix <command> --help' for command-specific help.
USAGE
    ;;
  *)
    echo "エラー: 不明なコマンド '$CMD'" >&2
    echo "利用可能なコマンドは 'helix help' で確認してください" >&2
    exit 1
    ;;
esac
