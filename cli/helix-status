#!/bin/bash
set -eo pipefail

# helix-status: プロジェクト全体の HELIX 状態を表示
# Usage: helix-status

case "${1:-}" in
  --help|-h)
    echo "Usage: helix status"
    echo ""
    echo "プロジェクト全体の HELIX 状態を表示します。"
    exit 0
    ;;
esac

export HELIX_HOME="${HELIX_HOME:-$HOME/ai-dev-kit-vscode}"
SCRIPT_DIR="$HELIX_HOME/cli"
YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
PROJECT_ROOT="${HELIX_PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
HELIX_DIR="$PROJECT_ROOT/.helix"
PHASE_FILE="$HELIX_DIR/phase.yaml"

if [[ ! -d "$HELIX_DIR" ]]; then
  echo "HELIX 未初期化。'helix init' で初期化してください。" >&2
  exit 1
fi

if [[ ! -f "$PHASE_FILE" ]]; then
  echo "phase.yaml が見つかりません。" >&2
  exit 1
fi

# --- JSON で phase.yaml を読む ---
PHASE_JSON=$(python3 "$YAML_PARSER" dump "$PHASE_FILE" 2>/dev/null)

echo "=== HELIX Project Status ==="
echo ""

# --- プロジェクト情報 ---
project=$(echo "$PHASE_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('project',''))" 2>/dev/null)
phase=$(echo "$PHASE_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('current_phase',''))" 2>/dev/null)
echo "Project: ${project:-unknown}"
echo "Phase:   ${phase:-unknown}"
echo ""

# --- ゲート状態 ---
echo "Gates:"
echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
gates = d.get('gates', {})
for g in ['G1', 'G1.5', 'G1R', 'G2', 'G3', 'G4', 'G5', 'G6', 'G7']:
    v = gates.get(g, {})
    if isinstance(v, dict):
        status = v.get('status', 'pending')
        date = v.get('date', '')
    else:
        status = str(v)
        date = ''
    icon = {'passed':'✓', 'failed':'✗', 'invalidated':'!', 'skipped':'—'}.get(status, ' ')
    date_str = f'  ({date})' if date else ''
    print(f'  {icon} {g:5s}  {status}{date_str}')
" 2>/dev/null
echo ""

# --- スプリント状態 ---
sprint_drive=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print((d.get('sprint', {}) or {}).get('drive', '') or '')
" 2>/dev/null || echo "")
sprint_step=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
s = d.get('sprint', {})
print(s.get('current_step', '') or 'N/A')
" 2>/dev/null || echo "N/A")

if [[ "$sprint_drive" == "fullstack" ]]; then
  echo "Sprint:"
  echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
sprint = d.get('sprint', {}) if isinstance(d.get('sprint', {}), dict) else {}
tracks = sprint.get('tracks', {}) if isinstance(sprint.get('tracks', {}), dict) else {}

phase_raw = str(sprint.get('phase') or 'A')
phase_label = {'A': 'A (並行実装)', 'B': 'B (結合)'}.get(phase_raw, phase_raw)

def track_value(name: str):
    raw = tracks.get(name, {})
    if not isinstance(raw, dict):
        return '.1a', 'active'
    stage_raw = str(raw.get('stage') or '.1a')
    stage = {'0.2': '.2', '0.3': '.3', '0.4': '.4', '0.5': '.5'}.get(stage_raw, stage_raw)
    status = str(raw.get('status') or 'active')
    return stage, status

be_stage, be_status = track_value('be')
fe_stage, fe_status = track_value('fe')
contract_raw = tracks.get('contract', {})
if isinstance(contract_raw, dict):
    contract_ci = str(contract_raw.get('ci') or 'pending')
else:
    contract_ci = 'pending'

print(f'  Phase:   {phase_label}')
print(f'  BE Track: {be_stage} ({be_status})')
print(f'  FE Track: {fe_stage} ({fe_status})')
print(f'  Contract CI: {contract_ci}')
" 2>/dev/null
  echo ""
elif [[ "$sprint_step" != "N/A" ]]; then
  echo "Sprint: $sprint_step"
  echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
steps = d.get('sprint', {}).get('steps', {})
current = d.get('sprint', {}).get('current_step', '')
for s in ['.1a', '.1b', '.2', '.3', '.4', '.5']:
    status = steps.get(s, {})
    if isinstance(status, dict):
        status = status.get('status', 'pending')
    icon = '✓' if status == 'completed' else ('→' if s == current else ' ')
    print(f'  {icon} {s}  [{status}]')
" 2>/dev/null
  echo ""
fi

# --- Reverse 状態 ---
has_reverse=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
rg = d.get('reverse_gates', {})
has = any(v.get('status','pending') != 'pending' for v in rg.values() if isinstance(v, dict))
print('yes' if has else 'no')
" 2>/dev/null || echo "no")

if [[ "$has_reverse" == "yes" ]]; then
  echo "Reverse Gates:"
  echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for rg in ['RG0', 'RG1', 'RG2', 'RG3']:
    v = d.get('reverse_gates', {}).get(rg, {})
    status = v.get('status', 'pending') if isinstance(v, dict) else 'pending'
    icon = {'passed':'✓', 'failed':'✗'}.get(status, ' ')
    print(f'  {icon} {rg}  {status}')
" 2>/dev/null
  echo ""
fi

reverse_status=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
reverse = d.get('reverse', {})
print(reverse.get('status', '') if isinstance(reverse, dict) else '')
" 2>/dev/null || echo "")

if [[ "$reverse_status" == "completed" ]]; then
  reverse_completed_at=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
reverse = d.get('reverse', {})
print(reverse.get('completed_at', '') if isinstance(reverse, dict) else '')
" 2>/dev/null || echo "")
  echo "Reverse: Reverse 完了 → Forward 接続待ち"
  if [[ -n "$reverse_completed_at" ]]; then
    echo "  completed_at: $reverse_completed_at"
  fi
  echo ""
fi

# --- レトロ ---
if [[ -d "$HELIX_DIR/retros" ]]; then
  retro_count=$(ls "$HELIX_DIR/retros/"*.md 2>/dev/null | wc -l)
  if [[ $retro_count -gt 0 ]]; then
    echo "Retros: $retro_count 件"
    ls -1 "$HELIX_DIR/retros/"*.md 2>/dev/null | while read -r f; do
      echo "  $(basename "$f")"
    done
    echo ""
  fi
fi

# --- 設計文書 ---
if [[ -d "$PROJECT_ROOT/docs/design" ]]; then
  design_count=$(ls "$PROJECT_ROOT/docs/design/"*.md "$PROJECT_ROOT/docs/design/"*.yaml 2>/dev/null | wc -l)
  if [[ $design_count -gt 0 ]]; then
    echo "Design Docs: $design_count 件"
    ls -1 "$PROJECT_ROOT/docs/design/" 2>/dev/null | head -10 | while read -r f; do
      echo "  $f"
    done
    echo ""
  fi
fi

# --- アクションガイド ---
action=$(echo "$PHASE_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
phase = (d.get('current_phase') or '').strip()
gates = d.get('gates', {})

failed = []
for gate in ['G1', 'G1.5', 'G1R', 'G2', 'G3', 'G4', 'G5', 'G6', 'G7']:
    value = gates.get(gate, {})
    status = value.get('status', 'pending') if isinstance(value, dict) else str(value)
    if status == 'failed':
        failed.append(gate)

if failed:
    print('FAILED:' + ','.join(failed))
else:
    actions = {
        'L1': 'helix plan draft で設計を開始',
        'L2': 'helix gate G2 で設計凍結ゲートを確認',
        'L3': 'helix gate G3 で実装着手ゲートを確認',
        'L4': 'helix sprint status でスプリント進捗確認',
        'L5': 'helix gate G5 でデザイン凍結ゲートを確認',
        'L6': 'helix gate G6 で RC 判定を実施',
        'L7': 'helix gate G7 の安定性確認後に helix pr を準備',
        'L8': '受入条件を確認し PO 承認へ進む',
    }
    print(actions.get(phase, 'helix status で状態を継続確認し、未通過ゲートを解消'))
" 2>/dev/null)

echo "Action Guide:"
if [[ "$action" == FAILED:* ]]; then
  failed_gates="${action#FAILED:}"
  echo "  該当ゲートの指摘事項を確認し修正"
  echo "  失敗ゲート: ${failed_gates:-unknown}"
else
  echo "  $action"
fi
