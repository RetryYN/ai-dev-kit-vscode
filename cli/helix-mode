#!/bin/bash
set -eo pipefail
# helix-mode: 開発モード管理
# Usage: helix mode [forward|reverse|scrum]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
PHASE_FILE="$HELIX_DIR/phase.yaml"
YP="$YAML_PARSER"

case "${1:-}" in
  --help|-h)
    cat <<'USAGE'
使い方: helix mode [モード]

引数なし: 現在のモードを表示
forward:  Forward HELIX (L1→L8) に切替
reverse:  Reverse HELIX (R0→R4) に切替
scrum:    HELIX Scrum（検証駆動開発）に切替
USAGE
    exit 0
    ;;
esac

if [[ ! -f "$PHASE_FILE" ]]; then
  echo "エラー: HELIX 未初期化。'helix init' で初期化してください。" >&2
  exit 2
fi

current=$(python3 "$YP" read "$PHASE_FILE" current_mode 2>/dev/null || echo "forward")

if [[ -z "${1:-}" ]]; then
  echo "現在のモード: $current"
  case "$current" in
    forward) echo "  Forward HELIX (L1→L8): ゲート駆動の新規開発" ;;
    reverse) echo "  Reverse HELIX (R0→R4): 既存コードからの設計復元" ;;
    scrum)   echo "  HELIX Scrum: 仮説検証駆動開発" ;;
  esac
  exit 0
fi

NEW_MODE="$1"
case "$NEW_MODE" in
  forward|reverse|scrum) ;;
  *) echo "エラー: 無効なモード '$NEW_MODE'（forward, reverse, scrum を指定）" >&2; exit 2 ;;
esac

if [[ "$current" == "$NEW_MODE" ]]; then
  echo "既に $NEW_MODE モードです"
  exit 0
fi

# 遷移制約チェック
if [[ "$current" == "reverse" && "$NEW_MODE" == "forward" ]]; then
  rev_status=$(python3 "$YP" read "$PHASE_FILE" reverse.status 2>/dev/null || echo "")
  if [[ "$rev_status" != "completed" ]]; then
    echo "エラー: Reverse が未完了です（status: $rev_status）。R4 まで完了してから Forward に切り替えてください。" >&2
    exit 3
  fi
fi

if [[ "$current" == "scrum" && "$NEW_MODE" == "forward" ]]; then
  # confirmed な仮説があるかチェック（scrum/backlog.yaml）
  if [[ -f "$HELIX_DIR/scrum/backlog.yaml" ]]; then
    confirmed=$(python3 "$YP" dump "$HELIX_DIR/scrum/backlog.yaml" 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
items = d.get('hypotheses', [])
if isinstance(items, list):
    c = sum(1 for h in items if isinstance(h, dict) and h.get('status') == 'confirmed')
else:
    c = 0
print(c)
" 2>/dev/null || echo "0")
    if [[ "$confirmed" == "0" ]]; then
      echo "WARN: confirmed な仮説がありません。Forward に切り替えますが、要件が不明確な可能性があります。" >&2
    fi
  fi
fi

python3 "$YP" write "$PHASE_FILE" current_mode "$NEW_MODE" 2>/dev/null
echo "モードを $current → $NEW_MODE に切り替えました"

case "$NEW_MODE" in
  forward) echo "  次のステップ: helix size でサイジングを実行" ;;
  reverse) echo "  次のステップ: helix reverse R0 で証拠収集を開始" ;;
  scrum)   echo "  次のステップ: helix scrum init で初期化" ;;
esac
