#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix scheduler <subcommand> [args...]

サブコマンド:
  add --schedule "<cron|+5m>" --task-type <type> --task-payload <payload> [--id <id>]
  list [--status <s>]
  cancel --id <id>
  status --id <id>
  run-due [--dry-run]
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  add|list|cancel|status|run-due)
    exec python3 "$SCRIPT_DIR/lib/scheduler_helper.py" \
      --db-path "$DB_PATH" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な scheduler subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
