#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix scheduler <subcommand> [args...]

サブコマンド:
  add       スケジュールを追加
  list      スケジュール一覧を表示
  cancel    スケジュールをキャンセル
  status    スケジュール状態を表示
  run-due   実行期限に達したスケジュールを処理
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  add|list|cancel|status|run-due)
    echo "Sprint X で実装予定 (PLAN-005)"
    exit 0
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な scheduler subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
