#!/bin/bash
set -eo pipefail

# helix-gate-api-check: API契約と実装のエンドポイント突合
# G4 static チェックとして使用
# Exit 0 = pass, Exit 1 = fail

PROJECT_ROOT="${HELIX_PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"

# --- API契約ファイルを探す ---
CONTRACT=""
for pattern in "docs/design/L3-api-contract.yaml" "docs/design/L3-api-contract.yml" "docs/design/L3-api-contract.md"; do
  if [[ -f "$PROJECT_ROOT/$pattern" ]]; then
    CONTRACT="$PROJECT_ROOT/$pattern"
    break
  fi
done

if [[ -z "$CONTRACT" ]]; then
  echo "  SKIP: API契約ファイルなし（docs/design/L3-api-contract.*）"
  exit 0
fi

# --- Python で突合実行 ---
TMPSCRIPT=$(mktemp /tmp/helix-api-check-XXXXXX.py)
trap 'rm -f "$TMPSCRIPT"' EXIT

cat > "$TMPSCRIPT" << 'PYEOF'
import re, sys, os
from pathlib import Path

contract_path = sys.argv[1]
project_root = sys.argv[2]

# --- 契約からエンドポイント抽出 ---
content = Path(contract_path).read_text()
contract_eps = set()

ext = Path(contract_path).suffix
if ext in ('.yaml', '.yml'):
    try:
        import yaml
        data = yaml.safe_load(content)
        if isinstance(data, dict):
            for key in ('contracts', 'endpoints', 'paths'):
                items = data.get(key, [])
                if isinstance(items, list):
                    for item in items:
                        if isinstance(item, dict):
                            method = item.get('method', 'GET').upper()
                            path = item.get('endpoint', item.get('path', ''))
                            if path:
                                contract_eps.add(f'{method} {path}')
                elif isinstance(items, dict):
                    for path, methods in items.items():
                        if isinstance(methods, dict):
                            for method in methods:
                                if method.upper() in ('GET','POST','PUT','DELETE','PATCH'):
                                    contract_eps.add(f'{method.upper()} {path}')
    except Exception:
        pass

for match in re.finditer(r'(GET|POST|PUT|DELETE|PATCH)\s+(/[^\s"]+)', content):
    contract_eps.add(f'{match.group(1)} {match.group(2)}')

if not contract_eps:
    print("  SKIP: API契約からエンドポイントを抽出できませんでした")
    sys.exit(0)

# --- 実装からエンドポイント抽出 ---
src_root = Path(project_root) / 'src'
if not src_root.exists():
    src_root = Path(project_root)

impl_eps = set()
patterns = [
    r'(?:router|app|server)\.(get|post|put|delete|patch)\s*\(\s*[\'"](/[^\'"]*)[\'"]',
    r'@(Get|Post|Put|Delete|Patch)\s*\(\s*[\'"](/[^\'"]*)[\'"]',
    r'@(?:app|router)\.(get|post|put|delete|patch)\s*\(\s*[\'"](/[^\'"]*)[\'"]',
]

for f in src_root.rglob('*'):
    if f.suffix not in ('.ts', '.tsx', '.js', '.jsx', '.py', '.go'):
        continue
    if any(p in str(f) for p in ('node_modules', '.next', '.git', '.helix', '__pycache__')):
        continue
    try:
        code = f.read_text()
    except Exception:
        continue
    for pat in patterns:
        for m in re.finditer(pat, code, re.IGNORECASE):
            method = m.group(1).upper()
            path = m.group(2)
            impl_eps.add(f'{method} {path}')

# --- 突合 ---
print(f"  API契約: {len(contract_eps)} endpoints")
print(f"  実装:    {len(impl_eps)} endpoints")

contract_only = contract_eps - impl_eps
impl_only = impl_eps - contract_eps

exit_code = 0

if contract_only:
    print("  FAIL: 契約にあるが未実装:")
    for ep in sorted(contract_only):
        print(f"    {ep}")
    exit_code = 1

if impl_only:
    print("  FAIL: 実装にあるが契約にない（未承認エンドポイント）:")
    for ep in sorted(impl_only):
        print(f"    {ep}")
    exit_code = 1

if not contract_only and not impl_only:
    print("  OK: 契約と実装が一致")

sys.exit(exit_code)
PYEOF

python3 "$TMPSCRIPT" "$CONTRACT" "$PROJECT_ROOT"
