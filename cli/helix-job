#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix job <subcommand> [args...]

サブコマンド:
  enqueue   ジョブを登録
  worker    ジョブ worker を起動
  status    ジョブ状態を表示
  cancel    ジョブをキャンセル
  retry     失敗ジョブを再試行
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  enqueue|worker|status|cancel|retry)
    exec python3 "$SCRIPT_DIR/lib/job_queue_helper.py" \
      --db-path "$DB_PATH" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な job subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
