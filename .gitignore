# HELIX runtime state (project-specific, auto-generated by helix-init / CLI)
# allowlist 方式: .helix/ 配下を全除外、人が書く設計ドキュメントだけ明示的に allow。
# サブディレクトリ (cli/.helix/ 等) にも適用するため **/.helix/ を使う。
**/.helix/**
!**/.helix/reverse/
!**/.helix/reverse/**
!**/.helix/scrum/
!**/.helix/scrum/**
!**/.helix/retros/
!**/.helix/retros/**
!**/.helix/session-summaries/
!**/.helix/session-summaries/**
!**/.helix/research/
!**/.helix/research/**
!**/.helix/patterns/
!**/.helix/patterns/**

.helix/budget/

# Codex CLI 副産物 (空ファイルが生成される)
.codex

# Codex 画像生成出力先 (docs/generated-assets.yaml で管理)
public/generated/

# 履歴アーカイブ（ローカル保管、Git 追跡対象外）
/docs/archive/

# シェル展開失敗ガード: `~` がリテラル文字列のまま mkdir されるケース防止
# (過去コミット 5314036 で混入した残骸の再発防止)
/~
/~/**

# 絶対パス風フォルダ混入防止 (スクリプトで ~ 展開失敗時に発生する典型パターン)
/home/
/Users/
/tmp/
/var/
/mnt/

# エディタ・OS 副産物
*~
*.swp
*.swo
*.bak
*.orig
.DS_Store
Thumbs.db

